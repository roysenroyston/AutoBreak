@model ShopMate.Models.Quotation

@{
    ViewBag.Title = "Edit";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

<script src="~/Content/ckeditor/ckeditor.js"></script>

@Html.StarkAjaxFormSubmiter("frmQuotation", "tbQuotation", true, "Action Successfully Executed")


@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}

<script type="text/javascript">
    $(function () {
        $('select').searchableOptionList({
            maxHeight: '250px'
        });
    });
</script>

@using (Html.BeginForm("Edit", "Quotation", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmQuotation" }))
{
    @Html.AntiForgeryToken()

    <!-- Main content -->
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Approve Quotation</h3>
                    </div>
                    <!-- form start -->

                    <div role="form">
                        <div class="box-body">
                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.SubTotal, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.SubTotal)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.VAT, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.VAT)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.Total, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.Total)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.AddedBy, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.AddedBy)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.customerId, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.customerId)

                                </div>
                            </div>
                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.Remarks, htmlAttributes: new { @class = "" })
                                <div class=" col-md-10">
                                    @Html.EditorFor(model => model.Remarks) 
                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.IssueDate, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.IssueDate)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.ValidUntil, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.ValidUntil)

                                </div>
                            </div>

                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.ModifiedBy, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    @Html.EditorFor(model => model.ModifiedBy)

                                </div>
                            </div>

                            <div class="form-group">
                                @Html.LabelFor(model => model.approved, htmlAttributes: new { @class = "" })
                                <div class="col-md-10">
                                    <div class="checkbox">
                                        @Html.EditorFor(model => model.approved)

                                    </div>
                                </div>
                            </div>




                        </div><!-- /.box-body -->
                        <div class="box-footer">
                            @Html.StarkInputButtion("Save", "submit", "btn btn-primary", "")
                            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

}


