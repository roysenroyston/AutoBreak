@model ShopMate.Models.Quotation

@{
    /**/

    ViewBag.Title = "Are you sure you want to delete";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}


@Html.StarkAjaxFormSubmiter("frmQuotation", "tbQuotation", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
            </h1>
        </section>
    }
}

<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of Quotation</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="col-xs-2">

                        <div class="clearfix"></div>

                        <br /><br /><br />

                        <div class="clearfix"></div>

                        <br /><br /><br />

                    </div>

                    <div class="col-xs-9" style="margin-left:10px;">

                        <div id="dvContainer" class="content invoice" style=" padding inherit; min-height 150mm; width:100%; ">

                            <div style="margin-bottom:50px;">

                            </div>
                            <div class="row" style="font-size:12px;text-align:center;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">


                                <div style="text-align:center;font-size:30px;font-weight:bold;"> Quotation</div>


                                <div style="text-align:left;margin-left:40px;">

                                    <div style="height:10px; margin-bottom:10px; ">

                                    </div>

                                    <div class="row">
                                        <div class="col-xs-12">

                                            <div style="width:96%;">
                                                <div class="col-xs-12">
                                                    <div class="col-xs-5" style="padding-left:60px;">Date: @Model.IssueDate</div>
                                                    <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Voucher No: @Model.Id </div>
                                                </div>
                                                <div class="clearfix"></div>

                                                <br />
                                                <div class="col-xs-12">
                                                    <div class="col-xs-5" style="padding-left:60px;">Issued by: @Model.AddedBy</div>
                                                </div>
                                                <div class="clearfix"></div>

                                                <br />

                                                <div class="col-xs-12">
                                                    <table class="table table-striped">
                                                        <thead style="background-color:#e5e2e2;">
                                                            <tr>
                                                                <th>Quantity</th>
                                                                <th>Description</th>
                                                                <th>Unit Price</th>
                                                                <th>Total Price</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @*<tr>
                                                                    <td>@Model.Quantity</td>
                                                                    <td>@Model.Description</td>
                                                                    <td>@Model.UnitPrice</td>
                                                                    <td>@Model.TotalPrice</td>
                                                                </tr>*@
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="height:10px; margin-bottom:20px;">

                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-xs-12">
                                    @*<div class="col-xs-5" style="padding-left:60px;">Name: @Model.receivedby</div>*@
                                    <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                                </div>
                            </div>
                        </div>
                        <div class="streaming-table">
                            <div class="box-footer">

                                @using (Html.BeginForm("Delete", "Quotation", FormMethod.Post, new { id = "frmQuotation" }))
                                {
                                    @Html.AntiForgeryToken()

                                    @Html.StarkInputButtion("Delete", "submit", "btn btn-danger", "")
                                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



