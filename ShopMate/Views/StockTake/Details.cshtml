                                <table class="table table-striped table-bordered">                                  
                                    @*<tr>
                                        <td>Fuel Attendant</td>
                                        <td>@Html.DisplayFor(model => model.)</td>
                                    </tr>
                                    <tr>
                                        <td>Stock Value</td>
                                        <td>@Html.DisplayFor(model => model.StockValue)</td>
                                    </tr>
                                    <tr>
                                        <td>Date Added</td>
                                        <td>@Html.DisplayFor(model => model.DateAdded)</td>
                                    </tr>
                                    <tr>
                                        <td>Branch</td>
                                        <td>@Html.DisplayFor(model => model.Warehouse)</td>
                                    </tr>*@
                                    @*<tr>
                                            <td>Route</td>
                                            <td>@Html.DisplayFor(model => model.Route)</td>
                                        </tr>*@
                                    @*<tr>
                                            <td>Route</td>
                                            <td>@Html.DisplayFor(model => model.ProductPrice)</td>
                                        </tr>*@


                                </table>
                                <div class="col-xs-11" style="margin-left:0%;">
                                    <table class="table table-striped table-bordered">
                                        @*<table class="table" style="font-size: 1.8vmin; width: 98%;height: auto;font-weight: 200;margin-right:2%; position: relative;">*@
                                        <thead style="background-color:#e5e2e2;">
