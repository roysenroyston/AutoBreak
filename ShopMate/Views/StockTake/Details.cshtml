                                                <th>Product</th>
                                                <th>Actual Qty</th>
                                                <th>Counted Qty</th>
                                                <th>Variance Qty</th>
                                                <th>variance Value</th>
                                                <th> Warehouse</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.StockTakeDetails)
