@model ShopMate.Models.Bank

@{
    ViewBag.Title = "Are you sure you want to delete"; 
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

@Html.StarkAjaxFormSubmiter("frmBank", "tbBank", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
} 

<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of Bank</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>@Html.DisplayNameFor(model => model.Name)</td>
                                    <td>@Html.DisplayFor(model => model.Name)</td>
                                </tr>

                            </table>
                            <div class="box-footer">
                                @using (Html.BeginForm("Delete", "Bank", FormMethod.Post, new {  id = "frmBank" }))
                                {
                                    @Html.AntiForgeryToken()

                                    @*<div class="form-actions no-color">
                                        <input type="submit" value="Delete" class="btn btn-default" />
                                        @Html.ActionLink("Back to List", "Index")
                                    </div>*@
                                    @Html.StarkInputButtion("Delete","submit","btn btn-danger","")
                                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                                }
                                </div>
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </div>
</section>
