@model IEnumerable<ShopMate.Models.LedgerAccount>
@{
    ViewBag.Title = "Accounts";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.MenuOpen = "Reports";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}


@section ScriptsOrCss{
    <link href="~/Content/UIControls/themes/default/easyui.css" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="~/Content/UIControls/themes/icon.css">
    <link href="~/Content/UIControls/demo/demo.css" rel="stylesheet" />
    <script src="~/Content/UIControls/jquery.min.js"></script>
    <script src="~/Content/UIControls/jquery.easyui.min.js"></script>
    <script type="text/javascript">

        function collapseAll() {
            $('.easyui-tree').tree('collapseAll');
        }
        function expandAll() {
            $('.easyui-tree').tree('expandAll');
        }

        function getChecked() {

            var nodes = $('.easyui-tree').tree('getChecked');
            var s = '';
            for (var i = 0; i < nodes.length; i++) {
                if (s != '') s += ',';
                s += nodes[i].id;
            }
        }


    </script>
}


<link href="~/Content/datetimepicker-master/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Content/datetimepicker-master/jquery.datetimepicker.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.js"></script>
<link href="~/Content/theme/plugins/datepicker/datepicker3.css" rel="stylesheet" type="text/css" />
<script src="~/Content/theme/plugins/datepicker/bootstrap-datepicker.js" type="text/javascript"></script>

<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
<script src="https://cdn.datatables.net/1.10.23/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.flash.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.html5.min.js"></script>
<script src=" https://cdn.datatables.net/buttons/1.6.5/js/buttons.print.min.js"></script>
<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');
        printWindow.document.write('<link href="../../Content/theme/dist/css/AdminLTE.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();


    });



    var isPosttime = "@ViewBag.timess";


    $(document).ready(function (e) {

        $('#stime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });
        $('#etime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });

        if (isPosttime == "1") {
            $('#stime').val("00:01");
            $('#etime').val("23:59");
        }
    });

</script>


<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>



<section class="content" style="background-image: url(@Url.Content("~/Content/bg/black-scales.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->
                @using (Html.BeginForm("Accounts", "Report", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmreport" }))
                {
                    <div class="col-xs-12">

                        <div class="clearfix"></div>
                        <br />

                        <div class="col-xs-12">
                            <input type="text" name="FromDate" required style="width: 150px;" value="@ViewBag.FromDate" placeholder="Pick From Date" id="txtCal" />
                            From Time: <input name="stime" required id="stime" type="text" value="@ViewBag.stime" style="width:60px;">
                            @*<script> $(function () { $("#txtCal").datepicker(); }); </script>*@

                        </div>
                        <div class="clearfix"></div>
                        <br />
                        <div class="col-xs-12">
                            <input type="text" required name="ToDate" style="width:150px;" value="@ViewBag.ToDate" placeholder="Pick To Date" id="txtCalTo" />
                            To Time:  <input required name="etime" id="etime" type="text" value="@ViewBag.etime" style="width:60px;">
                            @*<script> $(function () { $("#txtCalTo").datepicker(); }); </script>*@
                        </div>
                        <div class="clearfix"></div>
                        <br />
                        <div class="col-xs-12">
                            <input class="btn btn-default" value="Get" type="submit">
                        </div>

                        <div class="clearfix"></div>

                        <br /><br /><br />


                        <a class="btn btn-app" id="btnPrint">
                            <i class="fa fa-print"></i>
                            Print This
                        </a>

                    </div>
                }

            </section>


        </div>

        <div class="col-xs-9" style="margin-left:10px;">

            <div id="dvContainer" class="content invoice" style="padding: inherit; min-height: 312mm;  width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">

                    <div style="text-align:center;font-size:40px;font-weight:bold; margin-left:10%;">@ViewBag.company</div>
                    <div style="text-align:center;font-size:30px;font-weight:bold; margin-left:10%"> Accounts Report</div>

                    @if (ViewBag.timess == 0)
                    {
                        <div style="text-align:center;font-size:18px;font-weight:bold;"> @ViewBag.start to @ViewBag.end  </div>
                    }

                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>



                        <div class="row">

                            <div class="col-xs-12">

                                <div style="width:96%;">




                                    @foreach (var item in Model)
                                    {
                                        <div class="col-xs-6">
                                            <div class="box box-solid box-primary">

                                                <div class="box-header with-border">
                                                    <h3 class="box-title">@item.Name   </h3>
                                                    <div class="box-tools pull-right">
                                                        <button class="btn btn-box-tool" title="" data-toggle="tooltip" data-widget="collapse" data-original-title="Collapse">
                                                            <i class="fa fa-minus"></i>
                                                        </button>

                                                    </div>
                                                </div>



                                                <div class="box-body" style="overflow:auto;height:250px;">
                                                    <ul class="easyui-tree" data-options="url:'@Url.Content("~/Report/GetPageControls/" + item.Id + "?dfrom=" + ViewBag.FromDate + "&dto=" + ViewBag.ToDate + "&stime=" + ViewBag.stime + "&etime=" + ViewBag.etime + "&hit=" + ViewBag.timess)',method:'get',animate:true,checkbox:true,cascadeCheck:true,onCheck: function(node){getChecked();}"></ul>

                                                </div>
                                            </div>
                                        </div>
                                    }




                                </div>


                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>



                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <a class="btn btn-app" id="btnPrint">
            <i class="fa fa-print"></i>
            Print This
        </a>
    </div>
</section>
<script type="text/javascript">

    $(document).ready(function () {
        $('#tbInvoiceItem').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copy', 'csv', 'excel', 'pdf', 'print'
            ]
        });
    });
</script>
