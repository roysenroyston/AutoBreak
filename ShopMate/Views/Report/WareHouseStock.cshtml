

@model IEnumerable<ShopMate.ModelDto.WarehouseStockDto>
@{
    ViewBag.Title = "Warehouse Stock " + @ViewBag.branch;
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.MenuOpen = "Reports";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}

<link href="~/Content/datetimepicker-master/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Content/datetimepicker-master/jquery.datetimepicker.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.js"></script>
<link href="~/Content/theme/plugins/datepicker/datepicker3.css" rel="stylesheet" type="text/css" />
<script src="~/Content/theme/plugins/datepicker/bootstrap-datepicker.js" type="text/javascript"></script>

<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
<script src="https://cdn.datatables.net/1.10.23/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.flash.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.html5.min.js"></script>
<script src=" https://cdn.datatables.net/buttons/1.6.5/js/buttons.print.min.js"></script>



<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();


    });



    var isPosttime = "@ViewBag.timess";


    $(document).ready(function (e) {

        $('#stime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });
        $('#etime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });

        if (isPosttime == "1") {
            $('#stime').val("00:01");
            $('#etime').val("23:59");
        }
        let data = ''

        window.onload = function () {
            window.document.body.addEventListener('keydown', function (event) {
                //if (event.keyCode == 13 || event.keyCode == 16 || event.keyCode == 17) {
                //    event.preventDefault();
                //    return;
                //}

                if (event.ctrlKey) {
                    event.preventDefault();
                    return;
                }

                data += event.key
                console.log(data)
            });
        }

    });
    function cleartext() {
        $('#clearid').val('');
    }
</script>
<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>



<section class="content" style="background-image: url(@Url.Content("~/Content/bg/black-scales.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->
                @using (Html.BeginForm("WareHouseStock", "Report", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmreport" }))
                {
                <div class="col-xs-12">
           

                   
                    <div class="col-xs-12">
                   
                        <div class="form-group">
                            <label>Select Branch</label>
                            @Html.DropDownList("WarehouseId", null, new { @Id = "WarehouseId" })

                        </div>
                
                    </div>
                    <div class="clearfix"></div>
                    <br />
        
                    <br />
                    <div class="col-xs-12">
                        <input class="btn btn-default" value="Search" type="submit">
                    </div>

                    <div class="clearfix"></div>

                    <br /><br /><br />



                </div>
                }

            </section>


        </div>

        <div class="col-xs-9" style="margin-left:10px;">

            <div id="dvContainer" class="content invoice" style="padding: inherit; min-height: 312mm;  width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">

                    <div style="text-align:center;font-size:30px;font-weight:bold;margin-left:10%;">@ViewBag.company</div>
                    <div style="text-align:center;font-size:20px;font-weight:bold;margin-left:10%;"> Warehouse Stock Report</div>

                    @*<div style="text-align:center;font-size:15px;font-weight:lighter;">@ViewBag.ToDate </div>*@


                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>

                        <input id="clearid" type="text" />

                        <div class="row">

                            <div class="col-xs-12">

                                <div style="width:96%;">
                                    <table id="tbInvoiceItem" class="table table-striped table-bordered">
                                        <thead style="background-color:#e5e2e2;">
                                            <tr>
                                                <th>S.No</th>
                                                <th>Product Name </th>
                                                <th>Barcode</th>
                                                <th>Product Description</th>
                                                <th> Remaining Quantity </th>
                                                <th>Stock Value</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model != null)
                                            {
                                                int i = 1;
                                                foreach (var item in Model)
                                                {
                                                    <tr>
                                                        <td>@i</td>
                                                        <td> @item.ProductName </td>
                                                        <td>@item.Barcode</td>
                                                        <td> @item.ProductDescription </td>
                                                        <td> @item.Quantity </td>
                                                         <td> @item.stockAmount </td>
                                                    </tr>
                                                    i++;
                                                }

                                            }

                                        </tbody>
                                      
                                    </table>


                                </div>


                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>



                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @*<div>
            <a class="btn btn-app" id="btnPrint">
                <i class="fa fa-print"></i>
                Print This
            </a>
        </div>*@
</section>
<script type="text/javascript">

    $(document).ready(function () {
        $('#tbInvoiceItem').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copy', 'csv', 'excel', 'pdf', 'print'
            ]
        });
    });
</script>