
@model ShopMate.ModelDto.VATReport
@{
    ViewBag.Title = "VAT";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.MenuOpen = "Reports";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}

<link href="~/Content/datetimepicker-master/jquery.datetimepicker.css" rel="stylesheet" />
<script src="~/Content/datetimepicker-master/jquery.datetimepicker.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.min.js"></script>
<script src="~/Content/datetimepicker-master/build/jquery.datetimepicker.full.js"></script>
<link href="~/Content/theme/plugins/datepicker/datepicker3.css" rel="stylesheet" type="text/css" />
<script src="~/Content/theme/plugins/datepicker/bootstrap-datepicker.js" type="text/javascript"></script>


<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();


    });



    var isPosttime = "@ViewBag.timess";


    $(document).ready(function (e) {

        $('#stime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });
        $('#etime').datetimepicker({
            datepicker: false,
            format: 'H:i',
            step: 5
        });

        if (isPosttime == "1") {
            $('#stime').val("00:01");
            $('#etime').val("23:59");
        }
    });

</script>


<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>



<section class="content" style="background-image: url(@Url.Content("~/Content/bg/black-scales.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->
                @using (Html.BeginForm("VAT", "Report", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmreport" }))
                {
                    <div class="col-xs-12">

                        <div class="clearfix"></div>
                        <br />

                        <div class="col-xs-12">
                            <input type="text" name="FromDate" required style="width: 150px;" value="@ViewBag.FromDate" placeholder="Pick From Date" id="txtCal" />
                            From Time: <input name="stime" required id="stime" type="text" value="@ViewBag.stime" style="width:60px;">
                            @*<script> $(function () { $("#txtCal").datepicker(); }); </script>*@

                        </div>
                        <div class="clearfix"></div>
                        <br />
                        <div class="col-xs-12">
                            <input type="text" required name="ToDate" style="width:150px;" value="@ViewBag.ToDate" placeholder="Pick To Date" id="txtCalTo" />
                            To Time:  <input required name="etime" id="etime" type="text" value="@ViewBag.etime" style="width:60px;">
                            @*<script> $(function () { $("#txtCalTo").datepicker(); }); </script>*@
                        </div>
                        <div class="clearfix"></div>
                        <br />

                        <br />
                        <div class="col-xs-12">
                            <input class="btn btn-default" value="Search" type="submit">
                        </div>

                        <div class="clearfix"></div>

                        <br /><br /><br />


                        <a class="btn btn-app" id="btnPrint">
                            <i class="fa fa-print"></i>
                            Print This
                        </a>

                    </div>
                }

            </section>


        </div>

        <div class="col-xs-9" style="margin-left:10px;">

            <div id="dvContainer" class="content invoice" style=" padding inherit; min-height 312mm; width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">

                    <div style="text-align:center;font-size:30px;font-weight:bold;">@Model.companayname</div>
                    <div style="text-align:center;font-size:20px;font-weight:bold;"> VAT Report</div>
                    @*<div style="text-align:center;font-size:20px;font-weight:bold;">From @Model.datefrom To @Model.dateto</div>*@
                    <div style="text-align:center;font-size:14px;font-weight:bold;"> @ViewBag.start to @ViewBag.end  </div>

                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>



                        <div class="row">

                            <div class="col-xs-12">

                                <div style="width:96%;">
                                    <table id="tbInvoiceItem" class="table table-striped table-bordered">
                                        <thead style="background-color:#e5e2e2;">
                                            <tr>
                                                <th> </th>
                                                <th>Output TAX </th>
                                                <th> Amount </th>
                                            </tr>
                                        </thead>
                                        <tbody>

                                            <tr>
                                                <td>1</td>
                                                <td>Total Sales Including VAT  </td>
                                                <td> @Model.Sale </td>
                                            </tr>
                                            <tr>
                                                <td>2</td>
                                                <td>Total Sales Excluding VAT</td>
                                                <td>@Model.salesexcludevat </td>
                                            </tr>
                                            <tr>
                                                <td>3</td>
                                                <td>Total Taxable Sales (Excluding VAT) </td>
                                                <td>@Model.taxablesales</td>
                                            </tr>
                                            <tr>
                                                <td>4</td>
                                                <td> Total Non-taxable Sales </td>
                                                <td>@Model.nontaxablesales </td>
                                            </tr>
                                            <tr>
                                                <td>5</td>
                                                <td>VAT on Taxables Sales</td>
                                                <td> @Model.taxonsales</td>
                                            </tr>
                                            <tr>
                                                <td>6</td>
                                                <td>Sales Returns</td>
                                                <td>@Model.SaleReturn</td>
                                            </tr>
                                            <tr>
                                                <td>7</td>
                                                <td>Discounts Given</td>
                                                <td>@Model.discountsonsales</td>
                                            </tr>
                                            <tr style="background-color:#e5e2e2;">
                                                <th></th>
                                                <th> Input TAX</th>
                                                <th></th>
                                            </tr>
                                            <tr>
                                                <td>1</td>
                                                <td>Total Purchases Including VAT</td>
                                                <td>@Model.totalPurchase</td>
                                            </tr>
                                            <tr>
                                                <td>2</td>
                                                <td>Total Purchases Excluding VAT</td>
                                                <td> @Model.Totapurchaseexcludingvat</td>
                                            </tr>
                                            <tr>
                                                <td>1</td>
                                                <td>Total Raw Materials Purchases Including VAT</td>
                                                <td>@Model.totalRawMaterialsPurchase</td>
                                            </tr>
                                            <tr>
                                                <td>2</td>
                                                <td>Total Raw Materials Purchases Excluding VAT</td>
                                                <td> @Model.TotalRawMaterialsPurchaseexcludingvat</td>
                                            </tr>
                                            <tr>
                                                <td>3</td>
                                                <td>Total Taxable Purchases (Excluding VAT)</td>
                                                <td>@Model.taxablepurchases</td>
                                            </tr>
                                            <tr>
                                                <td>4</td>
                                                <td>Total Non-taxable Purchases</td>
                                                <td>@Model.nontaxablepurchase</td>
                                            </tr>
                                            <tr>
                                                <td>5</td>
                                                <td> VAT on Taxable Purchases</td>
                                                <td>@Model.taxonpurchases</td>
                                            </tr>

                                            <tr>
                                                <td>6</td>
                                                <td> Purchases Returns</td>
                                                <td>@Model.PurchaseReturn</td>
                                            </tr>
                                            <tr>
                                                <td>7</td>
                                                <td>Discount Given</td>
                                                <td>@Model.purchasesdiscount</td>
                                            </tr>
                                            <tr style="background-color:#e5e2e2;">
                                                <td></td>
                                                <td>NET VAT</td>
                                                <td> @Model.nettax</td>
                                            </tr>
                                            <tr>
                                                <td></td>
                                                <td> </td>
                                                <td> </td>
                                            </tr>

                                        </tbody>
                                        <tfoot style="background-color:#e5e2e2;">

                                        </tfoot>

                                    </table>


                                </div>


                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>



                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <a class="btn btn-app" id="btnPrint">
            <i class="fa fa-print"></i>
            Print This
        </a>
    </div>
</section>
