        var fiveedollars = $("#5dollars").text();
        var tenndollars = $("#10dollars").text();
        var twentyydollars = $("#20dollars").text();
        var fiftyydollars = $("#50dollars").text();
        var hundredddollars = $("#100dollars").text();
        var tbond = $("#totalcash").text();
        var tousd = $("#totalusd").text();
        // actual figures
        var twobond = $("#twobond").val();
        var fivebond = $("#fivebond").val();
        var tenbond = $("#tenbond").val();
        var twentybond = $("#twentybond").val();
        var fiftybond = $("#fiftybond").val();
