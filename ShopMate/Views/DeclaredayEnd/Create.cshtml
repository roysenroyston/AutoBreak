        var zip = $("#zipit").val() || 0;
        var fb = $("#fbc").val() || 0;
        var ac = $("#acl").val() || 0;
        var ecosh = $("#ecocash").val() || 0;
        var onem = $("#onemoney").val() || 0;
        var tels = $("#telecash").val() || 0;
        //var usd = $("#usd").val();
        //just this

        //actual totals money
        var m2bond = 2 * parseFloat(twobond) || 0;

        var m5bond = 5 * parseFloat(fivebond) || 0;
        var m10bond = 10 * parseFloat(tenbond) || 0;
        var m20bond = 20 * parseFloat(twentybond) || 0;
        var m50bond = 50 * parseFloat(fiftybond);
        var m100bond = 100 * parseFloat(hundredbond);
        var m1dollar = 1 * parseFloat(onedollar) || 0;
        var m2dollar = 2 * parseFloat(twodollars) || 0;
        var m5dollar = 5 * parseFloat(fivedollars) || 0;
        var m10dollar = 10 * parseFloat(tendollars) || 0;
        var m20dollar = 20 * parseFloat(twentydollars) || 0;
        var m50dollar = 50 * parseFloat(fiftydollars) || 0;
        var m100dollar = 100 * parseFloat(hundreddollars) || 0;
        var totalbond = m2bond + m5bond + m10bond + m20bond + m50bond + m100bond;
        var totalusd = m1dollar + m2dollar + m5dollar + m10dollar + m20dollar + m50dollar + m100dollar;
        //var totalusd = parseFloat(usdola);
        var overaltotal = totalbond + parseFloat(swp) + parseFloat(onem) + parseFloat(ecosh) + parseFloat(tels) + parseFloat(zip) + parseFloat(fb) + parseFloat(ac);

        //  var oldAmount = $("#SubTotal").val();
        //   var Sutotal = parseFloat(oldAmount) + parseFloat(amount);
        //  var tax = parseFloat(Sutotal) * 0.15;
        // var total = parseFloat(Sutotal) + parseFloat(tax);

        //displays

        $("#2bond").text(m2bond.toFixed(2));

        $("#5bond").text(m5bond.toFixed(2));
        $("#10bond").text(m10bond.toFixed(2));
        $("#20bond").text(m20bond.toFixed(2));
        $("#50bond").text(m50bond.toFixed(2));
        $("#100bond").text(m100bond.toFixed(2));
        $("#1dollar").text(m1dollar.toFixed(2));
        $("#2dollars").text(m2dollar.toFixed(2));
        $("#5dollars").text(m5dollar.toFixed(2));
        $("#10dollars").text(m10dollar.toFixed(2));
        $("#20dollars").text(m20dollar.toFixed(2));
        $("#50dollars").text(m50dollar.toFixed(2));
        $("#100dollars").text(m100dollar.toFixed(2));
        $("#totalAmount").val(overaltotal.toFixed(2));
        $("#zipitcash").text(parseFloat(zip).toFixed(2));
        $("#aclcash").text(parseFloat(ac).toFixed(2));
        $("#fbccash").text(parseFloat(fb).toFixed(2));
        $("#ecos").text(parseFloat(ecosh).toFixed(2));
        $("#telec").text(parseFloat(tels).toFixed(2));
        $("#onem").text(parseFloat(onem).toFixed(2));
        $("#swipes").text(parseFloat(swp).toFixed(2));

        //$("#totalusd").text(parseFloat(totalusd).toFixed(2))
        //$("#tusd").val(totalusd.toFixed(2));
        $("#totalcash").text(totalbond.toFixed(2));
        $("#totalcsh").val(totalbond.toFixed(2));
