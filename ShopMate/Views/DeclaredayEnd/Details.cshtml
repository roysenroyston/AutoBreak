<script type="text/javascript">

        $(document).ready(function () {
    GrossAmount();
    });
      function GrossAmount() {

    var oldfive = $("#5cents").text();
    var oldten = $("#10cents").text();
    var old25 = $("#25cents").text();
    var old50cents = $("#50cents").text();
    var old1 = $("#1dollr").text();
    var old2 = $("#2dollars").text();
    var old5 = $("#5dollars").text();
    var old10 = $("#10dollars").text();
    var old20 = $("#20dollars").text();
    var old50 = $("#50dollars").text();
    var old100 = $("#100dollars").text();
    var ttal = $("#tcash").text();
    // actual figures
    var fivec = $("#fivec").val();
    var tenc = $("#tenc").val();
    var cents25 = $("#cents25").val();
    var cents50 = $("#cents50").val();
    var dlo = $("#dla").val();
    var old2l = $("#2dla").val();
    var old5l = $("#5dla").val();
    var old10l = $("#10dla").val();
    var old20l = $("#20dla").val();
    var old50l = $("#50dla").val();
    var old100l = $("#100dla").val();
    var swp = $("#rtgs").val();
    var ecosh = $("#totalecocash").val();
    var onem = $("#onemoney").val();
    var tels = $("#telecash").val();
    //just this

    //actual totals money
    var m5 = 0.05 * parseFloat(fivec);
    var m10 = 0.1 * parseFloat(tenc);
    var m25 = 0.25 * parseFloat(cents25);
    var m50 = 0.5 * parseFloat(cents50);
    var m1l = 1 * parseFloat(dlo);
    var m2l = 2 * parseFloat(old2l);
    var m5l = 5 * parseFloat(old5l);
    var m10l = 10 * parseFloat(old10l);
    var m20l = 20 * parseFloat(old20l);
    var m50l = 50 * parseFloat(old50l);
    var m100l = 100 * parseFloat(old100l);
    var moneycash = m5 + m10 + m25 + m50 + m1l + m2l + m5l + m10l + m20l + m50l + m100l;

    var overaltotal = moneycash + parseFloat(swp)+ parseFloat(onem) + parseFloat(ecosh) + parseFloat(tels);

     // var oldAmount = $("#SubTotal").val();
     //  var Sutotal = parseFloat(oldAmount) + parseFloat(amount);
     // var tax = parseFloat(Sutotal) * 0.15;
     //var total = parseFloat(Sutotal) + parseFloat(tax);

    //displays

    $("#fivecc").text(m5.toFixed(2));
    $("#10cents").text(m10.toFixed(2));
    $("#25cents").text(m25.toFixed(2));
    $("#50cents").text(m50.toFixed(2));
    $("#1dollr").text(m1l.toFixed(2));
    $("#2dollars").text(m2l.toFixed(2));
    $("#5dollars").text(m5l.toFixed(2));
    $("#10dollars").text(m10l.toFixed(2));
    $("#20dollars").text(m20l.toFixed(2));
    $("#50dollars").text(m50l.toFixed(2));
    $("#100dollars").text(m100l.toFixed(2));
    $("#tcash").text(moneycash.toFixed(2));
    $("#totalcsh").val(moneycash.toFixed(2));
    $("#totalAmount").val(overaltotal.toFixed(2));
    $("#ecos").text(parseFloat(ecosh).toFixed(2));
    $("#telec").text(parseFloat(tels).toFixed(2));
    $("#onem").text(parseFloat(onem).toFixed(2));
    $("#swipes").text(parseFloat(swp).toFixed(2));
   // displays
     // $("#SubTotal").val(Sutotal.toFixed(2));
     // $("#VAT").val(tax.toFixed(2));
     //$("#Total").val(total.toFixed(2));
    }
</script>


