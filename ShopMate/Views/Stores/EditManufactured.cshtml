        //Add Multiple Materails.
    $("#addToList").click(function (e) {
        e.preventDefault();

        // if ($.trim($("#quantity").val()) == "" || $.trim($("#description").val()) == "" || $.trim($("#unitPrice").val()) == "") return;

        var RawMaterialid = $("#rawMaterial").val(),
            quantity = $("#quantity").val(),
            //description = $("#description").val(),
            Name = $("#rawMaterialName").val(),
            unitPrice = $("#unitPrice").val(),
            detailsTableBody = $("#detailsTable tbody");
        var totalz = parseFloat(unitPrice) * parseFloat(quantity);
        var productItem = '<tr><td>' + RawMaterialid + '</td><td>' + Name + '</td><td>' + quantity + '</td><td>' + unitPrice + '</td><td>' + (parseFloat(unitPrice) * parseFloat(quantity)) +  '</td> <td><a data-itemId="0" href="#" class="deleteItem">Remove</a></td></tr>';
        detailsTableBody.append(productItem);
        GrossAmount(totalz);
        clearItem();
    });
        //After Add A New Material In The List, Clear Clean The Form For Add More Material.
    function clearItem() {
        $("#quantity").val('');
        //$("#rawMaterialName").val('');
        $("#unitPrice").val('');
    }
        // After Add A New Order In The List, If You Want, You Can Remove It.
        $(document).on('click', 'a.deleteItem', function (e) {
            e.preventDefault();
            var $self = $(this);
            var totalz = $self.parents('tr').find('td:eq(4)').html();
            GrossAmount(-totalz);
            if ($(this).attr('data-itemId') == "0") {

                $(this).parents('tr').css("background-color", "#ff6347").fadeOut(800, function () {
                    $(this).remove();
                });
            }
        });
    function GrossAmount(totalz) {
        console.log(totalz);
        var oldAmount = $("#Total").val() || 0;
        var newtotal = parseFloat(oldAmount) + parseFloat(totalz);
        console.log("newtotal: " + newtotal);
        $("#Total").val(newtotal.toFixed(2));

    }
    function GrossAmount1(totalz) {
        console.log(totalz);
        var oldAmount = $("#Total").val() || 0;
        var newtotal = parseFloat(oldAmount) - parseFloat(totalz);
        console.log("newtotal: " + newtotal);
        $("#Total").val(newtotal.toFixed(2));

    }
    function GrossAmount(totalz) {
        var oldAmount = $("#Total").val();
        var total = parseFloat(oldAmount) + parseFloat(totalz);

        $("#Total").val(total.toFixed(2));

    }
        //After Click Save Button Pass All Data View To Controller For Save Database
        function saveOrder(data) {
            return $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: "/Stores/EditManufactured",
                data: data,
                success: function (result) {
                    alert(result);
                    location.reload();
                },
                error: function () {
                    alert("Error!")
                }
            });
        }
        //Collect Multiple JobCard List For Pass To Controller
        $("#saveOrder").click(function (e) {
            e.preventDefault();

            var GRVArr = [];

            GRVArr.length = 0;

            $.each($("#detailsTable tbody tr"), function () {
                GRVArr.push({
                    RawMaterialsId: $(this).find('td:eq(0)').html(),
                    RawMaterialsname: $(this).find('td:eq(1)').html(),
                    Quantity: $(this).find('td:eq(2)').html(),
                    //status: $(this).find('td:eq(4)').html(),
                    UnitPrice: $(this).find('td:eq(3)').html(),
                    TotalPrice: $(this).find('td:eq(4)').html(),
                      CutSheet: $(this).find('td:eq(5)').html(),
                });
            });

            var data = JSON.stringify({
                id: $("#manufacturedId").val(),
                FinishedGoodsName: $("#FinishedGoodsName").val(),
                Finishedqty: $("#finishedqty").val(),
                Cutsheet: $("#cutsheet").val(),               
                products: GRVArr
            });

            $.when(saveOrder(data)).then(function (response) {
                console.log(response);
            }).fail(function (err) {
                console.log(err);
            });
        });
</script>


