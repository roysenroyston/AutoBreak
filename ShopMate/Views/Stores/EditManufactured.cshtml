        var div = '<tr class="item-row" id="' + Id + '"RawMaterialsname="' + name + '"Quantity="' + qty + '"UnitPrice="' + price + '" >   <td> <a class="delete" value="' + totalz + '" href="javascript:;" title="Remove row">X</a> &nbsp; ' + RawMaterialsId + '</td> <td>'  + RawMaterialsname + '</td> <td>' + Quantity + '</td> <td> ' + UnitPrice + '</td>   </tr>';

        $("#tbody").append(div);
        GrossAmount(totalz);
