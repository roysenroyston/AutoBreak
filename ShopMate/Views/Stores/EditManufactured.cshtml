@model ShopMate.Models.Stores
@{
    ViewBag.Title = "Edit";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
@section ScriptsOrCss
{
    <script src="~/Content/ckeditor/ckeditor.js"></script>
    <script src="~/Content/DataTable/new/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="~/Scripts/quagga.js"></script>
}





@Html.StarkAjaxFormSubmiter("frmStores", "tbStores", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}
<script type="text/javascript">

    function addInv2(RawMaterialsId,RawMaterialsname, Quantity, UnitPrice) {

        // var remainingquantity = document.getElementById("remainq" + id).value;
        var Id = RawMaterialsId;
