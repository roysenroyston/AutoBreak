@using (Html.BeginForm("Manufacture", "Stores", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmStores" }))
{
    @Html.AntiForgeryToken()
    <!-- Main content -->
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title"> Edit Manufacturing Form</h3>
                    </div><!-- /.box-header -->
                    <!-- form start -->
                    <div role="form">
                        <div class="box-body">
                            <div class="row">

                                <div class="col-md-3">
                                    <div class="form-group">
                                        @Html.DropDownList("CutSheet", (IEnumerable<SelectListItem>)ViewBag.OrderNumber, "select CutSheet Number", new { @Id = "cutsheet" })
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        @* Finished Product: @Model.FinishedGoodsName*@
                                        <input type="text" value="" id="FinishedGoodsName" name="FinishedGoodsName" placeholder="Finished Product" class="form-control" readonly />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        @* Finished Product Quantity: @Model.FinishedGoodsQuantity*@
                                        <input type="number" value="" id="finishedqty" name="finishedqty" placeholder="Finished Product Quantity" class="form-control" readonly />
                                    </div>
                                </div>
                                <div class="col-md-3" hidden>
                                    <div class="form-group">
                                        @* Finished Product Quantity: @Model.FinishedGoodsQuantity*@
                                        <input type="number" value="" id="manufacturedId" name="manufacturedId" placeholder="manufacturedId" class="form-control" readonly />
                                    </div>
                                </div>
                                <div class="row">

                                    <div class="col-md-12">
                                        <table class="table table-bordered table-hover" id="tab_logic">
                                            <thead>
                                                <tr>
                                                    <th style="width:25%">Raw Material</th>
                                                    <th style="width:25%">Quantity</th>
                                                    @*<th style="width:40%">Description</th>*@
                                                    <th style="width:25%">Unit Price</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>
                                                        @Html.DropDownList("RawMaterials", null, new { @Id = "rawMaterial" })
                                                    </td>
                                                    <td>
                                                        <input type="number" id="quantity" name="quantity" placeholder="Quantity" class="form-control" />
                                                    </td>
                                                    @*<td>
                                <input type="text" id="description" name="description" placeholder="Description Name" class="form-control" />
                            </td>*@
                                                    <td>
                                                        <input type="number" id="unitPrice" name="unitPrice" placeholder="Unit Price" class="form-control" value="0.00" />
                                                    </td>
                                                    <td style="display:none">
                                                        <input type="text" id="rawMaterialName" name="rawMaterialName" placeholder="rawMaterial Name" class="form-control" value="" />
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <div class="col-md-12">
                                            <a id="addToList" class="btn btn-primary">Add To List</a>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <table id="detailsTable" class="table table-bordered table-hover">
                                            <thead>
                                                <tr>
                                                    <th style="width:15%">Raw material</th>
                                                    <th style="width:20%">Name</th>
                                                    <th style="width:20%">Quantity</th>
                                                    @*<th style="width:30%">Description</th>*@
                                                    <th style="width:20%">Unit Price</th>
                                                    <th style="width:20%">Total Price</th>
                                                    <th style="width:20%" hidden>CutSheet No</th>
                                                    <th style="width:10%"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="tbody"></tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Total Price</label>
                                    <br />
                                    <input type="number" id="Total" name="Total" placeholder="0.00" value="0.00" class="form-control" style=" width: 20%" readonly />

                                </div>
                            </div>
                        <div class="box-footer">
                            <button id="saveOrder" type="submit" class="btn btn-primary">Save</button>
                            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

