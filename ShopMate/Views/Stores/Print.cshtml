@model ShopMate.ModelDto.StoresDto
@{
    ViewBag.Title = "JOBCARD";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}


<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();

    });


</script>


<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>




<section class="content" style="background-color: #996600; background-image: url(@Url.Content("~/Content/bg/brick-wall-dark.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <!--<section class="content">-->
                <!-- Small boxes (Stat box) -->

                <!--<div class="col-xs-12">

                    <div class="clearfix"></div>
                    <br />


                    <div class="clearfix"></div>

                    <br /><br /><br />


                    <a class="btn btn-app" id="btnPrint">
                        <i class="fa fa-print"></i>
                        Print This
                    </a>

                </div>


            </section>-->


        </div>

        <div class="col-xs-9">

            <div id="dvContainer" class="content invoice" style="padding :inherit; min-height :312mm; width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;text-align:center;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">
                    <div style="text-align:center;font-size:25px;font-weight:bold;display:inline-block;"> Used Raw materials   </div>

                    <figure>
                        <img id="KediLogo" class="pull-left" img src="~/Content/bg/toserudo.jpeg" style="width:250px; height:200px;margin-top:1%;" />

                    </figure>
                    <div style="text-align: right;font-size:14px;margin-right:5%;">
                        <p>CutSheet No: @Model.cutsheetNumber</p><br>
                        <p>Stores No: @Model.strnum</p><br>
                        <p>Finished Product : @Model.Finishedgoods</p><br />
                        <p>Product Quantity : @Model.productqty</p><br />
                        <p>Customer Name : @Model.remarks</p><br />
                        <small class="pull-right">Date: @Model.DateAdded </small><br>
                    </div>

               

                    @*<div style="text-align:center;font-size:40px;font-weight:bold;">@Model.companayname</div>*@

                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>



                        <div class="row">
                            <div class="col-xs-12">
                                <div style="width:96%;">

                                    <section class="invoice">
                                        <!-- title row -->
                                        <!-- info row -->
                                        <!-- /.row -->
                                        <!-- Table row -->
                                        <div class="row">


                                            <div class="col-md-12">
                                                <table class="table " border="1">
                                                    <thead style="background-color:#e5e2e2;">
                                                        <tr>
                                                            <th>Description</th>
                                                            <th>Quantity</th>
                                                            <th>Price</th>
                                                            <th>Total</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in Model.material)
                                                        {
                                                            <tr>
                                                                <td>@Html.DisplayFor(model => item.name)</td>
                                                                <td>@Html.DisplayFor(model => item.Quantity)</td>
                                                                <td>@Html.DisplayFor(model => item.price)</td>
                                                                <td>@Html.DisplayFor(model => item.total)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>

                                            <hr />
                                            <div class="col-md-6 col-md-offset-8">
                                                <div class="form-group">
                                                    @*@Html.LabelFor(model => model.Totalprice, new { @class = "" })<br />
                                        @Html.DisplayFor(model => model.Totalprice)*@
                                                    <strong>Total Price:@Model.Totalprice</strong><br />
                                                </div>

                                                <div class="form-group">
                                                    @Html.Hidden("purchasedate", DateTime.Now)
                                                </div>

                                            </div>
                                        </div>

                                    </section>


                                </div>
                            </div>
                            <div style="float: none; position: static; overflow: visible; page-break-inside: avoid;">
                                <table class="table table-striped" align="left" style="width:92%; height:auto; border-collapse: collapse; ">

                                    <tr>
                                        <td>
                                            <strong>
                                                RAW MATERIALS ISSUED BY:&nbsp;&nbsp;
                                            </strong>
                                            <p>
                                            <p> &nbsp;&nbsp;</p>
                                            Name..........................................................................
                                            Signature.....................................................................

                                            </p>
                                        </td>
                                    </tr>
                                </table>
                                <table class="table table-striped" align="left" style="width:92%; height:auto; border-collapse: collapse; ">
                                    @*<tr>
                            <th>Goods recieved in good order</th>

                        </tr>*@


                                    <tr>
                                        <td>
                                            <strong>RAW MATERIALS RECEIVED BY:&nbsp;&nbsp;</strong>
                                            <p>
                                            <p> &nbsp;&nbsp;</p>
                                            Name..........................................................................
                                            Signature.................................................................

                                            </p>
                                        </td>

                                </table>
                            </div>


                        </div>
                        @*<div style="height:10px; margin-bottom:20px;">

            </div>*@



                    </div>


                    @*<div class="clearfix"></div>*@


                </div>


                    <div class="row">
                        <div class="col-xs-12">
                            <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                            <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                        </div>
                    </div>
                </div>
        </div>
    </div>

    <div>
        <a class="btn btn-app" id="btnPrint">
            <i class="fa fa-print"></i>
            Print This
        </a>
    </div>
</section>

