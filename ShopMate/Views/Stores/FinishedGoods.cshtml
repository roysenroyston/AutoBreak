    function cleartext(){
        $('.dataTables_filter input').val('');
    }
    function getproducts() {
        var oTableProduct = "";
        var ControlerNameProduct = "@Url.Content("~/SaleOrder")";
                oTableProduct = $("#tbProduct").dataTable({
            "bRetrieve": true,
            "bProcessing": true,
            "dom": 'lBfrtip',
            "sAjaxSource": "@Url.Content("~/SaleOrder/GetProduct")",
            "pageLength": 50,
            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
            "aoColumns": [
                 {
                     "mRender": function (oObj, type, row,full) {

                         var content = '<img src="/Uploads/' + row[3] + '" style="width:50px;height:50px;" /> &nbsp;<b>' + row[6] + '</b>&nbsp;' + row[0] + ' <br/> <br/>';

                         return content;
                     }

                 },

            {
                "mRender": function (oObj, type, row) {


                    var buttons = '<div class="text-center"> <input type="number" value="1" style="width:44px;" id="Qty' + row[2] + '"/> <button onclick="addInv(' + row[2] + ',' + row[4] + ',' + row[5] + ',\'' + row[0] + '\','+row[4]+')" type="button" id="btnPlus" class="btn btn-default btn-xs btn-warning" title="Click To Add" > <i class="fa fa-plus"></i></button></div>';

                    return buttons;
                }

            },

            ]

        });

        $(".dataTables_filter input").on("keypress", function (e) {
            if (e.which == 13) {
                document.getElementById("btnPlus").click();
            }
        });

        $("#tbody").on('click', ".delete", function () {
            var amt = $(this).attr("value");
            $(this).parents('.item-row').remove();
            GrossAmount(-amt);
        });

        $("#saveOrder").on('click', function () {
            if (confirm("are you sure you want to add finished good!") == true) {
                var products = [];

                //$("tr.item-row").each(function () {
                    //$this = $(this);
                    //products.push({ productId: $this.attr("id"), Quantity: $this.attr("qty") });
                    //console.log(product);
        //        var products = [];

                        products.length = 0;

                        $.each($("#tbInvoiceItem tbody tr"), function () {
                            products.push({
                                description: $(this).find('td:eq(0)').html(),
                                Quantity: $(this).find('td:eq(1)').html(),
                                UnitPrice: $(this).find('td:eq(2)').html(),
                                Cutsheet: $(this).find('td:eq(3)').html(),
                                Qty: $(this).find('td:eq(4)').html()
                            });

                         });

                            $.ajax({
                                url: "/Stores/FinishedGoods",
                                type: "POST",
                                data: {
                                    'product': products,
                                    'FinishedGoodsName': $("#FinishedGoodsName").val(),
                                    'FinishedGoodsQty': $("#finishedqty").val(),
                                    'storesId': $("#test").val(),
                                    //'CustomerUserId': $("#CustomerUserId").val(),
                                    //'SaleNote': $("#SaleNote").val(),
                                    //'TaxName': $(".selecttax").val(),/*norlin */
                                    //'CustomerOrderNumber': $("#CustomerOrderNumber").val(),
                                    //'QuotationId':$("#QuotationId").val(),
                                },
                                dataType: 'json',
                                success: function (result) {
                                    if (result == "Done") {
                                        console.log(result)
                                        $.sticky('<br/> Saved ', { stickyClass: 'success' });
                                        window.location = "@Env.GetSiteRoot()/Stores/FinishedGoods";
                                    }
                                    else {
                                        $.sticky('<br/> You cannot add more than what you have! <br/> ' + result + '', { stickyClass: 'error' });
                                    }
                                }, error: function () { $.sticky('<br/> ! Something went wrong. <br/> ' + result + '', { stickyClass: 'error' }); }
                            });


            }
        });
    }

