@model ShopMate.ModelDto.InternalDNoteDto

@{
    /**/

    ViewBag.Title = "Details";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
<section class="content-header">
    <h1>
        @ViewBag.Title
        <small>Details</small>
    </h1>
</section>
<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of Order</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>Order Id</td>
                                    <td id="idyangu">@Html.DisplayFor(model => model.OrderNumber)</td>
                                </tr>
                                <tr>
                                    <td>Warehouse From</td>
                                    <td>@Html.DisplayFor(model => model.WarehouseFrom)</td>
                                </tr>
                                <tr>
                                    <td>Warehouse To</td>
                                    <td>@Html.DisplayFor(model => model.WarehouseTo)</td>
                                </tr>
                                @*<tr>
                <td>Supplier</td>
                <td>@Html.DisplayFor(model => model.supplier)</td>
            </tr>
            <tr>
                <td>Date Purchased</td>
                <td>@Html.DisplayFor(model => model.purchasedate)</td>
            </tr>*@


                            </table>
                            <div class="col-xs-11" style="margin-left:0%;">
                                <table class="table table-striped table-bordered">
                                    @*<table class="table" style="font-size: 1.8vmin; width: 98%;height: auto;font-weight: 200;margin-right:2%; position: relative;">*@
                                    <thead style="background-color:#e5e2e2;">
                                        <tr>
                                            <th>PRODUCT CODE</th>
                                            <th>DESCRIPTION</th>
                                            <th>QUANTITY</th>
                                            @*<th></th>*@
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.items)
                                        {
                                            <tr>
                                                <td>@item.Name</td>
                                                <td>@item.Description</td>
                                                <td>@item.Quantity</td>
                                                @*<td></td>*@
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                            <div class="box-footer">
                                @Ajax.ModalDialogActionLink("Dispatch", "Dispatch/" + Model.OrderNumber, "Dispatch", "btn btn-primary")
                               @*<button id="Dispatch" type="submit" class="btn btn-primary">Dispatch1</button>*@

                                @Html.ActionLink("Back to List", "StockShippingOrder", null, new { @class = "btn btn-primary" })
                            </div>
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(document).ready(function () {

        $("#Dispatch").click(function (e) {
            var Id = $("#idyangu").Name;
            console.log( "Id is: " + Id);
            $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: "/Order/Dispatch" + Id,
                data: "",
                success: function (result) {
                    alert("Saved");
                    location.reload();
                },
                error: function (xhr, status, error) {
                    var errorMessage = xhr.status + ': ' + xhr.statusText
                    alert('Error - ' + errorMessage);
                }
            });


        });
    });
    </script>

