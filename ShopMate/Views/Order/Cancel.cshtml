@model ShopMate.ModelDto.InternalDNoteDto

@{
    /**/

    ViewBag.Title = "Cancel";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

@Html.StarkAjaxFormSubmiter("frmOrder", "tbOrder", true, "Action Successfully Executed")
<section class="content-header">
    <h1>
        @ViewBag.Title
        <small>Details</small>
    </h1>
</section>
<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Cancel</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>Warehouse From :  @Model.WarehouseFrom </td>
                                    @*<td>@Html.DisplayFor(model => model.WarehouseFrom)</td>*@
                                </tr>
                                <tr>
                                    <td>Warehouse To : @Model.WarehouseTo</td>
                                    @*<td>@Html.DisplayFor(model => model.WarehouseTo)</td>*@
                                </tr>



                            </table>
                            <div class="col-xs-11" style="margin-left:0%;">
                                <table class="table table-striped table-bordered">
                                    @*<table class="table" style="font-size: 1.8vmin; width: 98%;height: auto;font-weight: 200;margin-right:2%; position: relative;">*@
                                    <thead style="background-color:#e5e2e2;">
                                        <tr>
                                            <th>PRODUCT NAME</th>
                                            <th>DESCRIPTION</th>
                                            <th>QUANTITY</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.items)
                                        {
                                            <tr>
                                                <td>@item.Name</td>
                                                <td>@item.Description</td>
                                                <td>@item.Quantity</td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="footer">
                    @using (Html.BeginForm("Cancel", "Order", FormMethod.Post, new { id = "frmOrder" }))
                    {
                        @Html.AntiForgeryToken()

                        @Html.StarkInputButtion("Delete", "submit", "btn btn-danger", "")
                        @Html.ActionLink("Back to List", "StockShippingOrder", null, new { @class = "btn btn-primary" })
                    }
                </div>
            </div>
        </div>
    </div>
</section>

