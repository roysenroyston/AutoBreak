@model ShopMate.Models.Order


@{
    ViewBag.Title = "Create";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

<script src="~/Content/ckeditor/ckeditor.js"></script>

@Html.StarkAjaxFormSubmiter("frmOrder", "tbOrder", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}
<script type="text/javascript">
    $(function () {
        $('select').searchableOptionList({
            maxHeight: '250px'
        });
    });
</script>
@using (Html.BeginForm("Create", "Order", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmOrder" }))
{
    @Html.AntiForgeryToken()
    <!-- Main content -->
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Fill Order Form</h3>
                    </div><!-- /.box-header -->
                    <!-- form start -->
                    <div role="form">
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(model => model.supplier, new { @class = "" })
                                        @Html.DropDownList("userId", null, new { @Id = "supplier" })

                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(model => model.goods, new { @class = "" })
                                        <input type="text" id="goods" name="goods" placeholder="Description" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <table class="table table-bordered table-hover" id="tab_logic">
                                        <thead>
                                            <tr>
                                                <th style="width:40%">Quantity</th>
                                                <th style="width:30%">Description</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <input type="number" id="quantity" name="quantity" placeholder="Quantity" class="form-control" />
                                                </td>
                                                <td>
                                                    <input type="text" id="description" name="description" placeholder="Description Name" class="form-control" />
                                                </td>

                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="col-md-12">
                                        <a id="addToList" class="btn btn-primary">Add To List</a>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <table id="detailsTable" class="table table-bordered table-hover">
                                        <thead>
                                            <tr>
                                                <th style="width:15%">Quantity</th>
                                                <th style="width:30%">Description</th>

                                                <th style="width:10%"></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="box-footer">
                            <button id="saveOrder" type="submit" class="btn btn-primary">Create New Order</button>
                            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<script>
    //Add Multiple Materails.
    $("#addToList").click(function (e) {
        e.preventDefault();



        var quantity = $("#quantity").val(),
            description = $("#description").val(),

            detailsTableBody = $("#detailsTable tbody");
        if (quantity > 0) {
            error: function (xhr, status, error) {
                var errorMessage = xhr.status + ': ' + xhr.statusText
                alert('Error - ' + errorMessage);
            }
        }
else {
                var productItem = '<tr><td>' + quantity + '</td><td>' + description + '</td><td><a data-itemId="0" href="#" class="deleteItem">Remove</a></td></tr>';
                detailsTableBody.append(productItem);
                clearItem();
            }
   
      
    });
    //After Add A New Material In The List, Clear Clean The Form For Add More Material.
    function clearItem() {
        $("#quantity").val('');
        $("#description").val('');

    }
    // After Add A New Order In The List, If You Want, You Can Remove It.
    $(document).on('click', 'a.deleteItem', function (e) {
        e.preventDefault();
        var $self = $(this);
        if ($(this).attr('data-itemId') == "0") {
            $(this).parents('tr').css("background-color", "#ff6347").fadeOut(800, function () {
                $(this).remove();
            });
        }
    });

    //After Click Save Button Pass All Data View To Controller For Save Database
    function saveOrder(data) {
        return $.ajax({
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            type: 'POST',
            url: "/Order/Create",
            data: data,
            success: function (result) {
                alert("Saved");
                location.reload();
            },
            error: function (xhr, status, error) {
                var errorMessage = xhr.status + ': ' + xhr.statusText
                alert('Error - ' + errorMessage);
            }
        });
    }
    //Collect Multiple JobCard List For Pass To Controller
    $("#saveOrder").click(function (e) {
        e.preventDefault();

        var GRVArr = [];

        GRVArr.length = 0;

        $.each($("#detailsTable tbody tr"), function () {
            GRVArr.push({
                Quantity: $(this).find('td:eq(0)').html(),
                Description: $(this).find('td:eq(1)').html(),

            });
        });

        var data = JSON.stringify({
            supplier: $("#supplier").val(),
            goods: $("#goods").val(),
            OrderrMaterials: GRVArr
        });

        $.when(saveOrder(data)).then(function (response) {
            console.log(response);
        }).fail(function (err) {
            console.log(err);
        });
    });
</script>



