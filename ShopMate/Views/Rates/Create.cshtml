@model ShopMate.Models.Rate

@{
    ViewBag.Title = "Create";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

<script src="~/Content/ckeditor/ckeditor.js"></script>

@Html.StarkAjaxFormSubmiter("frmRates", "tbRates", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}
<script type="text/javascript">
        $(function () {
            $('select').searchableOptionList({
                maxHeight: '250px'
            });
    });

    $(document).ready(function () {
        $('#RefreshPage').click(function () {

            setTimeout(
                function () {
                    window.location.reload(true);
                }, 800);
        });
    });

</script>
@using (Html.BeginForm("Create", "Rates", FormMethod.Post))
{
    @Html.AntiForgeryToken()
          <!-- Main content -->
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Fill Currency Rates Form</h3>
                    </div><!-- /.box-header -->
                    <!-- form start -->
                    <div role="form">
                        <div class="box-body">

                            <div class="col-xs-4">
                                <div class="form-group">

                                    @*@Html.LabelFor(model => model.PaymentMode, htmlAttributes: new { @class = "" })*@
                                    @*@Html.DropDownList("PaymentModes", " -Select Payment Mode- ")<br />
                    @Html.EditorFor(model => model.PaymentMode)*@
                                    <label>Currency</label>
                                    @Html.DropDownListFor(x => x.CurrencyId, (SelectList)ViewBag.Currency, " -Select Currency- ", htmlAttributes: new { @class = "form-control" })

                                </div>
                            </div>
                        </div>
                        <br>
                        <div class="box-body">
                            <div class="col-xs-4">
                                <div class="form-group">

                                    @Html.LabelFor(model => model.CurrencyRate, htmlAttributes: new { @class = "" })
                                    @Html.EditorFor(model => model.CurrencyRate)

                                </div>
                            </div>
                        </div>

                            <div class="form-group">
                                @Html.Hidden("DateModified", DateTime.Now)
                            </div>





                        </div>


                    <div class="box-footer">

                        <input type="submit" id="RefreshPage" value="Create New" class="btn btn-primary">
                        @*@Html.StarkInputButtion("Create New", "submit", "btn btn-primary", "")*@
                        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                    </div>
                    </div>
            </div>
        </div>
      
    </section>

}


