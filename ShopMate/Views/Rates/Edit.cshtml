@model ShopMate.Models.Rates





@{
    ViewBag.Title = "Edit";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

<script src="~/Content/ckeditor/ckeditor.js"></script>

@Html.StarkAjaxFormSubmiter("frmRates", "tbRates", true, "Action Successfully Executed")


@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}

<script type="text/javascript">
        $(function () {
            $('select').searchableOptionList({
                maxHeight: '250px'
            });
        });
</script>

@using (Html.BeginForm("Edit", "Rates", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmRates" }))
{
    @Html.AntiForgeryToken()

        <!-- Main content -->
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Edit Rates</h3>
                    </div>
                    <!-- form start -->

                    <div role="form">
                        <div class="box-body">


                            <div class="form-group">
                                @Html.LabelFor(model => model.ecocash, new { @class = "" })
                                @Html.EditorFor(model => model.ecocash)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.telecash, new { @class = "" })
                                @Html.EditorFor(model => model.telecash)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.bond, new { @class = "" })
                                @Html.EditorFor(model => model.bond)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.rtgs, new { @class = "" })
                                @Html.EditorFor(model => model.rtgs)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.onemoney, new { @class = "" })
                                @Html.EditorFor(model => model.onemoney)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.usd, new { @class = "" })
                                @Html.EditorFor(model => model.usd)
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.fca, new { @class = "" })
                                @Html.EditorFor(model => model.fca)
                            </div>
                          
                            <div class="form-group">
                                @Html.Hidden("datemod", DateTime.Now)
                            </div>
                          

                        </div><!-- /.box-body -->
                        <div class="box-footer">
                            @Html.StarkInputButtion("Save", "submit", "btn btn-primary", "")
                            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

}


