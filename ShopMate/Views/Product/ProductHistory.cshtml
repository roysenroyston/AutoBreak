@model ShopMate.ModelDto.ProductHistoryDto

@{
    /**/

    ViewBag.Title = "ProductHistory";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
<section class="content-header">
    <h1>
        @ViewBag.Title
        <small>Details</small>
    </h1>
</section>
<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Product History</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">

                        <div class="streaming-table">
                            <div id="div1" >
                             
                                <div class="col-xs-11" style="margin-left:0%;">
                                    <table class="table table-striped table-bordered">
                                        <tr>
                                            <td>Product Id</td>
                                            <td>@Html.DisplayFor(model => model.Id)</td>
                                        </tr>
                                        <tr>
                                            <td>Product Name</td>
                                            <td>@Html.DisplayFor(model => model.ProductName)</td>
                                        </tr>
                                        <tr>
                                            <td>Is Active</td>
                                            <td>@Html.DisplayFor(model => model.IsActive)</td>
                                        </tr>
                                        <tr>
                                            <td>Sale Price</td>
                                            <td>@Html.DisplayFor(model => model.SalePrice)</td>
                                        </tr>
                                        <tr>
                                            <td>Purchase Price</td>
                                            <td>@Html.DisplayFor(model => model.PurchasePrice)</td>
                                        </tr>
                                        <tr>
                                            <td>Remaining Qauntity</td>
                                            <td>@Html.DisplayFor(model => model.RemainingQty)</td>
                                        </tr>
                                    </table>
                                    <table class="table table-striped table-bordered">
                                        <thead style="background-color:#e5e2e2;">
                                            <tr>
                                                @*<th>S No</th>
        <th>Product Id</th>*@
                                                <th>Product Name</th>
                                                <th>Quantity</th>
                                                <th>Unit Price</th>
                                                <th>Total Amount</th>
                                                <th>TotalAmountWithTax</th>
                                                <th>Transaction Date</th>
                                                <th>Description</th>
                                                <th>RemainingQty</th>

                                            </tr>
                                        </thead>
                                        <tbody>


                              
                                            @foreach (var item in Model.items)
                                            {
                                                   

                                            <tr>
                                                @*<td>@i</td>
        <td>@item.ProductId</td>*@
                                                <td>@item.ProductName</td>
                                                <td>@item.Quantity</td>
                                                <td>@item.UnitPrice</td>
                                                <td>@item.TotalPurchaseAmount</td>
                                                <td>@item.TotalSaleAmount</td>
                                                <td>@item.DateAdded</td>
                                                <td>@item.InventoryTypeId</td>
                                                <td>@item.RemainingQty</td>
                                            </tr>
                                   
                                            }



                                        </tbody>
                         
                                    </table>
                                </div>                              
                            </div>
                            <div class="box-footer">

                                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                                <button onclick="printContent('div1')" btn btn-primary>Print</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function printContent(el) {
        var divEl = document.getElementById(el);
        var allInputs = divEl.querySelectorAll("input,select,textarea");
        for (var counter = 0; counter < allInputs.length; counter++) {
            var input = allInputs.item(counter);
            input.setAttribute("value", input.value);
        }
        var restorepage = document.body.innerHTML;
        var printcontent = document.getElementById(el).innerHTML;
        document.body.innerHTML = printcontent;
        window.print();
        document.body.innerHTML = restorepage;
    }
    $(document).ready(function () {

        $("#Dispatch").click(function (e) {
            var Id = $("#idyangu").Name;
            console.log("Id is: " + Id);
            $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: "/Order/Dispatch" + Id,
                data: "",
                success: function (result) {
                    alert("Saved");
                    location.reload();
                },
                error: function (xhr, status, error) {
                    var errorMessage = xhr.status + ': ' + xhr.statusText
                    alert('Error - ' + errorMessage);
                }
            });
            GrossAmount(Sales);


            function GrossAmount(Sales) {
                console.log(Sales);
                var oldAmount = $("#sales").val() || 0;
                var newtotal = parseFloat(oldAmount) + parseFloat(Sales);
                console.log("newtotal: " + newtotal);
                $("#Sales").val(newtotal.toFixed(2));

            }

        });
    });
</script>

