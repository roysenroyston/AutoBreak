@model ShopMate.Models.Product

@{
    ViewBag.Title = "Create";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
 
<script src="~/Content/ckeditor/ckeditor.js"></script>
<script src="~/Scripts/quagga.js"></script>

<link href="~/Content/Site.css" rel="stylesheet" />

@Html.StarkAjaxFormSubmiter("frmProduct", "tbProduct", true, "Action Successfully Executed")
 
@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}
<script type="text/javascript">
        $(function () {
            $('select').searchableOptionList({
                maxHeight: '250px'
            });
        });
   
let data = ''

window.onload = function () {
     window.document.body.addEventListener('keydown', function(event){
        if( event.keyCode == 13 || event.keyCode == 16 ||  event.keyCode == 17 ) {
                event.preventDefault();
                    return;
                }

                if(event.ctrlKey) {
                    event.preventDefault();
                    return;
                }

        data += event.key
        console.log(data)
    });
}

    //BarCode reader
        function order_by_occurrence(arr) {
            var counts = {};
            arr.forEach(function (value) {
                if (!counts[value]) {
                    counts[value] = 0;
                }
                counts[value]++;
            });

            return Object.keys(counts).sort(function (curKey, nextKey) {
                return counts[curKey] < counts[nextKey];
            });
        }
        function load_quagga() {
            if ($('#barcode-scanner').length > 0 && navigator.mediaDevices && typeof navigator.mediaDevices.getUserMedia === 'function') {



                Quagga.init({
                    inputStream: {
                        name: "Live",
                        type: "LiveStream",
                        numOfWorkers: navigator.hardwareConcurrency,
                        target: document.querySelector('#barcode-scanner')
                    },
                    decoder: {
                        readers: ['ean_reader', 'ean_8_reader', 'code_39_reader', 'code_39_vin_reader', 'codabar_reader', 'upc_reader', 'upc_e_reader']
                    }
                }, function (err) {
                    if (err) { console.log(err); return }
                    Quagga.initialized = true;
                    Quagga.start();
                });

                var last_result = [];
                if (Quagga.initialized == undefined) {
                    Quagga.onDetected(function (result) {
                        var last_code = result.codeResult.code;
                        last_result.push(last_code);
                        if (last_result.length > 20) {
                            code = order_by_occurrence(last_result)[0];
                            last_result = [];
                            Quagga.stop();
                            debugger
                            $("#hdnBarcode").val(last_code);
                            //$.ajax({
                            //    type: "POST",
                            //    url: '/products/get_barcode',
                            //    data: { upc: code }
                            //});
                        }
                    });
                }

            }
        };
        $(document).ready(function () {

          //  load_quaga();
        });
    //clear things
        function clearTextbox() {
            $("#Name").val('');
            $("#hdnBarcode").val('');
            $("#PurchasePrice").val('');
            $("#SalePrice").val('');
            $("#Discount").val('');
            $("#HSN").val('');

           
    }
    
    $(document).ready(function () {
        $('#RefreshPage').click(function () {

            setTimeout(
                function () {
                    window.location.reload(true);
                }, 800);
        });
    });
  



</script>
@using (Html.BeginForm("Create", "Product", FormMethod.Post, new { enctype = "multipart/form-data",id = "frmProduct"  }))
{
    @Html.AntiForgeryToken()
          <!-- Main content -->
    <section class="content">
       
        <div id="barcode-scanner" style="display:none;"></div>
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Fill Product Form</h3>
                    </div><!-- /.box-header -->
                    <!-- form start -->
                    <div role="form">
                        <div class="box-body" id="barcode-scanner">
                            <div id="barcode-scanner"></div>

                            <div class="form-group">
                                @Html.LabelFor(model => model.Name, new { @class = "" })
                                @Html.EditorFor(model => model.Name, new { @Id = "Name", @class = "form-control" })
                            </div>
                            <div class="form-group" hidden>
                                @Html.LabelFor(model => model.ProductCategoryId, new { @class = "" })
                                @Html.DropDownList("ProductCategoryId", " -Select- ")
                                @Html.StarkDropDownAjaxLink("/ProductCategory/Create", "AddMore", "")
                            </div>

                            <div class="form-group">
                                @Html.LabelFor(model => model.ProductCaseId, new { @class = "" })
                                @Html.DropDownList("ProductCaseId", " -Select-  Product Case Id")
                                @Html.StarkDropDownAjaxLink("/Product/Create", "AddMore", "")
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.NumOfSinglesInCase, new { @class = "" })
                                @Html.EditorFor(model => model.NumOfSinglesInCase, new { @Id = "NumOfSinglesInCase", @class = "form-control" })
                            </div>
                            <div class="form-group">
                                @Html.LabelFor(model => model.ProductDescription, new { @class = "" })
                                @Html.EditorFor(model => model.ProductDescription, new { @Id = "Description", @class = "form-control" })
                            </div>

                            <div class="form-group">
                                @Html.LabelFor(model => model.BarCode, new { @class = "" })
                                @Html.EditorFor(model => model.BarCode, new { htmlAttributes = new { @class = "form-control", @id = "hdnBarcode" } })
                            </div>
            
                                <div class="form-group">
                                    <strong>Product Type</strong>
                                    <select name="ProductType" id="productType">
                                        <option value="">-Select Product Type -</option>
                                        <option value="SINGLE">SINGLE</option>
                                        <option value="CASE">CASE</option>
                                    </select>
                                </div>
                         
                <div class="form-group">
                                    <label>Purchase Price</label>
                                    @*@Html.LabelFor(model => model.PurchasePrice, new { @class = "" })*@
                                    @Html.EditorFor(model => model.PurchasePrice, new { @Id = "PurchasePrice", @class = "form-control" })
                                </div>
                                <div class="form-group">
                                    @Html.LabelFor(model => model.SalePrice, new { @class = "" })
                                    @Html.EditorFor(model => model.SalePrice, new { @Id = "SalePrice", @class = "form-control" })
                                </div>
                                <div class="form-group" hidden>
                                    @Html.LabelFor(model => model.ProductImage, new { @class = "" })
                                    <input id="ProductImage" name="ProductImage" type="file" />

                                </div>
                                <div class="form-group" hidden>
                                    @Html.LabelFor(model => model.Discount, new { @class = "" })
                                    @Html.EditorFor(model => model.Discount, new { @Id = "Discount", @class = "form-control" })
                                </div>
                                <div class="form-group">
                                    @Html.Hidden("AddedBy", Env.GetUserInfo("userid"))
                                </div>
                                <div class="form-group">
                                    @Html.Hidden("DateAdded", DateTime.Now)
                                </div>
                                <div class="form-group">
                                    @Html.Hidden("ModifiedBy", Env.GetUserInfo("userid"))
                                </div>
                                <div class="form-group">
                                    @Html.Hidden("DateModied", DateTime.Now)
                                </div>
                                <div class="form-group">
                                    @Html.LabelFor(model => model.IsActive, new { @class = "" })
                                    @Html.EditorFor(model => model.IsActive)
                                </div>
                                <div class="form-group">
                                    @Html.LabelFor(model => model.StockAlert, new { @class = "" })
                                    @Html.EditorFor(model => model.StockAlert)
                                </div>
                                <div class="form-group">
                                    @Html.LabelFor(model => model.TaxId, new { @class = "" })
                                    @*@Html.DropDownList("TaxId", " -Select- ")*@
                                    @Env.TaxUC(1)
                                </div>
                                <div class="form-group" hidden>
                                    @Html.LabelFor(model => model.WarehouseId, new { @class = "" })
                                    @*@Env.WareHouseUC(1)*@
                                    @Html.DropDownList("WareHouse", " -Select- ")
                                </div>




                            </div>
                            <div class="box-footer">
                                @*<input type="submit" value="Create New" class="btn btn-primary" onclick="clearTextbox();">*@
                                @*@Html.StarkInputButtion("Create New","submit","btn btn-primary","")*@
                                <input type="submit" id="RefreshPage" value="Create New" class="btn btn-primary">
                                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </section>
}

