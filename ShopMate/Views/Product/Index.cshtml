    // update product prices using jquerry
    function updatep() {

        $("#upbtn").click(function () {


            var catId = $("#categoryID").val();
            var pernt = $("#percnt").val();

            $.ajax({
                type: "POST",
                //url: "~/UpdatePrice?Id=" + catId + "&addprice=" + pernt + "",
               url: "@Url.Action("UpdatePrice", "Product")?Id="+ catId +" &addprice= "+ pernt+"",

                datatype: "json",
                data: '{Id:' + catId + ', addprice: "' + pernt + '"}',
                success: function () {
                   
                    $("#upbtn").closest("tr").find("td:eq(4)").text(400);
                    $('#progressmodal').modal('hide');
                   
                    loadProducts();
                },
                error: function (req, textStatus, errorThrown) {
                    //this is going to happen when you send something different from a 200 OK HTTP
                    alert('Ooops, something happened: ' + textStatus + ' ' + errorThrown);
                }

            });


        });
    }
