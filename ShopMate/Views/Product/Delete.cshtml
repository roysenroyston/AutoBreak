@model ShopMate.Models.Product

@{
    ViewBag.Title = "Are you sure you want to delete";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}


@Html.StarkAjaxFormSubmiter("frmProduct", "tbProduct", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}

<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of Product</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">
                  
                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>Name</td>
                                    <td>@Html.DisplayFor(model => model.Name)</td>
                                </tr>
                                <tr>
                                    <td>ProductCategoryId</td>
                                    <td>@Html.DisplayFor(model => model.ProductCategoryId)</td>
                                </tr>
                                <tr>
                                    <td>BarCode</td>
                                    <td>@Html.DisplayFor(model => model.BarCode)</td>
                                </tr>
                                <tr>
                                    <td>PurchasePrice</td>
                                    <td>@Html.DisplayFor(model => model.PurchasePrice)</td>
                                </tr>
                                <tr>
                                    <td>SalePrice</td>
                                    <td>@Html.DisplayFor(model => model.SalePrice)</td>
                                </tr>
                                <tr>
                                    <td> &nbsp;</td>
                                    <td> <img src="~/Uploads/@Model.ProductImage" width="200" /> </td>
                                </tr>
                                <tr>
                                    <td>AddedBy</td>
                                    <td>@Html.DisplayFor(model => model.AddedBy)</td>
                                </tr>
                                <tr>
                                    <td>DateAdded</td>
                                    <td>@Html.DisplayFor(model => model.DateAdded)</td>
                                </tr>
                                <tr>
                                    <td>ModifiedBy</td>
                                    <td>@Html.DisplayFor(model => model.ModifiedBy)</td>
                                </tr>
                                <tr>
                                    <td>DateModied</td>
                                    <td>@Html.DisplayFor(model => model.DateModied)</td>
                                </tr>
                                <tr>
                                    <td>IsActive</td>
                                    <td>@Html.DisplayFor(model => model.IsActive)</td>
                                </tr>
                                <tr>
                                    <td>StockAlert</td>
                                    <td>@Html.DisplayFor(model => model.StockAlert)</td>
                                </tr>
                                <tr>
                                    <td>TaxId</td>
                                    <td>@Html.DisplayFor(model => model.TaxId)</td>
                                </tr>
                                <tr>
                                    <td>WarehouseId</td>
                                    <td>@Html.DisplayFor(model => model.WarehouseId)</td>
                                </tr>
                                <tr>
                                    <td>Discount</td>
                                    <td>@Html.DisplayFor(model => model.Discount)</td>
                                </tr>

                            </table>
                            <div class="box-footer">

                                  @using (Html.BeginForm("Delete", "Product", FormMethod.Post, new {  id = "frmProduct" }))
                                {
                                    @Html.AntiForgeryToken()

                                    @Html.StarkInputButtion("Delete","submit","btn btn-danger","")
                                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



