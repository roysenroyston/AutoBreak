@{
    ViewBag.Title = "Store Item List";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.MenuOpen = "Resources";
}
@section ScriptsOrCss
{

    <link href="~/Content/DataTable/new/dataTables.bootstrap.css" rel="stylesheet" type="text/css" />
    <script src="~/Content/DataTable/new/jquery.dataTables.min.js" type="text/javascript"></script>
    <script src="~/Content/DataTable/new/dataTables.buttons.min.js" type="text/javascript"></script>
    <script src="~/Content/DataTable/new/jszip.min.js" type="text/javascript"></script>
    <script src="~/Content/DataTable/new/pdfmake.min.js" type="text/javascript"></script>
    <script src="~/Content/DataTable/new/vfs_fonts.js" type="text/javascript"></script>
    <script src="~/Content/DataTable/new/buttons.html5.min.js" type="text/javascript"></script>
    <link href="~/Content/DataTable/new/jquery.dataTables.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/DataTable/new/buttons.dataTables.min.css" rel="stylesheet" type="text/css" />
    <script src="~/Content/DataTable/new/buttons.print.min.js"></script>
    <script src="~/Content/DataTable/new/buttons.colVis.min.js"></script>
}
<section class="content-header">
    <h1>
        @ViewBag.Title
    </h1>
</section>

<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="col-xs-2">


        <section class="content">
            <!-- Small boxes (Stat box) -->
            @using (Html.BeginForm("Supplier", "Statements", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmreport" }))
            {
                <div class="col-xs-12">

                    <div class="clearfix"></div>
                    <br />

                    <div class="col-xs-12">
                        <input type="text" name="FromDate" required style="width: 150px;" value="@ViewBag.FromDate" placeholder="Pick From Date" id="txtCal" />
                        From Time: <input name="stime" required id="stime" type="text" value="@ViewBag.stime" style="width:60px;">
                        @*<script> $(function () { $("#txtCal").datepicker(); }); </script>*@

                    </div>
                    <div class="clearfix"></div>
                    <br />
                    <div class="col-xs-12">
                        <input type="text" required name="ToDate" style="width:150px;" value="@ViewBag.ToDate" placeholder="Pick To Date" id="txtCalTo" />
                        To Time:  <input required name="etime" id="etime" type="text" value="@ViewBag.etime" style="width:60px;">
                        @*<script> $(function () { $("#txtCalTo").datepicker(); }); </script>*@
                    </div>
                    <div class="clearfix"></div>
                    <br />
                    <div class="col-xs-12">
                        @Html.DropDownList("CustomerId")
                    </div>
                    <div class="clearfix"></div>
                    <br />
                    <div class="col-xs-12">
                        <input class="btn btn-default" value="Search" type="submit">
                    </div>

                    <div class="clearfix"></div>

                    <br /><br /><br />


                    <a class="btn btn-app" id="btnPrint">
                        <i class="fa fa-print"></i>
                        Print This
                    </a>

                </div>
            }

        </section>


    </div>
    <div class="row">
        <div class="col-xs-12">
            <div class="box box-solid box-primary">

                <div class="box-body">
                    <!-- Split button -->
                    <div class="margin">
                        <div class="btn-group">
                            @*@Ajax.ModalDialogActionLink("Create Quick", "Create", "Create ", "btn btn-dropbox")*@
                        </div>
                        <div class="btn-group">
                            @*<a href="~/Stores/Create" class="btn btn-default">Receive Raw Materials</a>*@
                        </div>
                    </div>
                    <!-- flat split buttons -->
                </div><!-- /.box-body -->
            </div>
            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">@ViewBag.Title</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="margin">

                        <div class="streaming-table">
                            <span id="found" class="label label-info"></span>

                            <table id="tbInvoiceItem" class="table table-striped table-bordered" style="height:12%;">
                                <thead style="background-color:#e5e2e2;">
                                    <tr>
                                        <th>Product Name </th>

                                        <th>Quantity</th>
                                        <th>Price</th>
                                        <th>Total Amount</th>
                                        @*<th>Supplier </th>*@
                                        <th> Date Supplied </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        int i = 1;
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td> @item.dated </td>
                                                <td>@item.ProductName</td>
                                                <td> @item.Quantity </td>
                                                <td> @item.saleprice </td>
                                                <td>@item.totalamount</td>
                                            </tr>
                                            i++;
                                        }

                                    }

                                </tbody>

                                <tfoot style="background-color:#e5e2e2;">
                                    <tr>
                                        <th></th>
                                        <th></th>
                                        <th></th>
                                        <th style="text-align:right">Total:</th>

                                    </tr>


                                </tfoot>

                            </table>


                            <div id="summary">
                                <div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="box box-solid box-primary">

                <div class="box-body">
                    <!-- Split button -->
                    <div class="margin">
                        <div class="btn-group">

                        </div>
                        <div class="btn-group">
                            <a href="~/Stores/Create" class="btn btn-default">Receive Raw Matrials</a>
                        </div>
                    </div>
                    <!-- flat split buttons -->
                </div><!-- /.box-body -->
            </div>
        </div>
    </div>
</section>





