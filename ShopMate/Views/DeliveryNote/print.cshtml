@model ShopMate.ModelDto.DNoteDto

@{
    ViewBag.Title = "DeliveryNote";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}


<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();

    });


</script>

<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>




<section class="content" style="background-color: #996600; background-image: url(@Url.Content("~/Content/bg/brick-wall-dark.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->

                <div class="col-xs-12">

                    <div class="clearfix"></div>
                    <br />


                    <div class="clearfix"></div>

                    <br /><br /><br />


                    <a class="btn btn-app" id="btnPrint">
                        <i class="fa fa-print"></i>
                        Print This
                    </a>

                </div>


            </section>


        </div>

        <div class="col-xs-9">

            <div id="dvContainer" class="content invoice" style="padding :inherit; min-height :312mm; width:100%; ">

                <div style="margin-bottom:50px;">

                </div>


                <div class="row" style="font-weight:bold;font-size:12px;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">

                    <div class="pull-right" style="text-align:right;margin-right:5%;">
                        <address>
                            <strong>@Model.CompanyName</strong><br>
                            @Html.Raw(Model.CompanyAddress)<br>
                            @Html.Raw(Model.CompanyContact)
                        </address>
                        <small class="pull-right">Date:@DateTime.Now.ToString("MMM/dd/yyyy") </small>
                    </div>
                    <div>

                       
                        <div>

                        </div>
                    </div>
                    <div style="text-align:center;font-size:20px;font-weight:bold;color:blue;margin-right:12%;"> DELIVERY NOTE &nbsp;&nbsp;<label style="color:red;">@Model.Id</label>   </div>

                    <div style="text-align:left;margin-left:30px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>


                        <div class="row">
                            <div class="col-xs-12">

                                <!-- info row -->
                                <div class="row invoice-info" style="width:90%; margin:6%">
                                    <table class="table table-bordered" style="width:30%; border:1px solid;display:inline-block; ">
                                        <tr>
                                            <th>To</th>
                                        </tr>
                                        <tr>
                                            <td>
                                                @Model.CustomerUser<br>
                                                @Html.Raw(Model.ToInfo)
                                            </td>

                                        </tr>
                                    </table>

                                    <table class="table pull-right table-bordered" align="center" style="width:45%;height:auto;text-align:center;">
                                        <tr>
                                            <th>Invoice No.</th>

                                        </tr>
                                        <tr>
                                            <td>@Model.invoiceNo</td>

                                        </tr>
                                        <tr>
                                            <th>Order No.</th>
                                        </tr>
                                        <tr>


                                            <td>@Model.OrderNo</td>
                                        </tr>
                                    </table>

                                </div>

                                <!-- /.row -->
                                <!-- Table row -->
                                <div class="row">

                                    <div class="col-xs-11" style="margin-left:6%;">
                                        <table class="table table-striped" border="1" align="left" style="width:98%; height:auto;border:1px solid; border-collapse: collapse; font-size:10px;">
                                            <thead style="background-color:#e5e2e2;">
                                                <tr>
                                                    <th>Quantity</th>
                                                    <th>Description</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.items)
                                                {
                                                    <tr>
                                                        <td>@item.Quantity</td>
                                                        <td>@item.Description</td>
                                                    </tr>
                                                }

                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                            </div>
                        </div>


                    </div>

                    <div style="height:10px; margin-bottom:20px;">

                    </div>



                </div>


                <div class="clearfix" style="height:25%;"></div>               
                <div class="bottom" style="margin-left:6%;">
                    <table class="table table-striped" align="left" style="width:98%; height:auto; border-collapse: collapse; font-size:90%;">
                        <tr>
                            <th>Goods recieved in good order</th>

                        </tr>
                        <tr>
                            <td>
                                Name.............................................
                                id.............................................
                                signature.............................................
                            </td>
                        </tr>
                    </table>





                    @*<p>
                Goods recieved in good order<br />
                Name&nbsp;&nbsp;....................&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ID&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </p>
                ID*@
                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        @*<div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>*@
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <a class="btn btn-app" id="btnPrint">
            <i class="fa fa-print"></i>
            Print This
        </a>
    </div>
</section>

