@model ShopMate.Models.DeliveryNote
@{
    ViewBag.Title = "Delivery Note";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}


<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();

    });


</script>


<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>




<section class="content" style="background-color: #996600; background-image: url(@Url.Content("~/Content/bg/brick-wall-dark.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->

                <div class="col-xs-12">

                    <div class="clearfix"></div>
                    <br />


                    <div class="clearfix"></div>

                    <br /><br /><br />


                    <a class="btn btn-app" id="btnPrint">
                        <i class="fa fa-print"></i>
                        Print This
                    </a>

                </div>


            </section>


        </div>

        <div class="col-xs-9">

            <div id="dvContainer" class="content invoice" style=" padding inherit; min-height 312mm; width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;text-align:center;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">


                    <div style="text-align:center;font-size:30px;font-weight:bold;"> Delivery Note</div>


                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>



                        <div class="row">
                            <div class="col-xs-12">
                                <div style="width:96%;">

                                    <section class="invoice">
                                        <!-- title row -->
                                        <div class="row">
                                            <div class="col-xs-12">
                                                <h2 class="page-header">
                                                    @*<i class="fa fa-globe"></i> Invoice #@Model.InvoiceId*@
                                                    <i class="fa fa-globe"></i> Delivery Note No. <label style="color:red;">@Model.Id</label>
                                                    <small class="pull-right">Date:@DateTime.Now.ToString("MMM/dd/yyyy") </small>
                                                </h2>
                                            </div>
                                            <!-- /.col -->
                                        </div>
                                        <!-- info row -->
                                        <div class="row invoice-info">
                                            <div class="col-sm-2 invoice-col">
                                                <img src="#" style="width:100px;height:100px;" />
                                            </div>
                                            <div class="col-sm-4 invoice-col">
                                                <address style="margin-left:auto;">
                                                    <strong>Roselt Mitchell (PVT) LTD</strong><br />
                                                    T/A METAL COMPONENTS MANUFACTURERS<br />
                                                    PO BOX BE 1043<br />
                                                    BELVEDERE 42 Edison Crescent <br />
                                                    Graniteside, harare <br />
                                                    Tell: 04772300 <br />
                                                </address>
                                            </div>

                                        </div>
                                        <!-- /.row -->
                                        <!-- Table row -->
                                        <div class="row">

                                            <div class="col-xs-12">
                                                <div class="col-xs-5" style="padding-left:60px;">Date: @Model.purchasedate</div>
                                                <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Voucher No: @Model.Id </div>
                                            </div>
                                            <div class="clearfix"></div>

                                            <br />
                                            <div class="col-xs-12">
                                                <div class="col-xs-5" style="padding-left:60px;">Supplier: @Model.supplier</div>
                                                <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Order Number: @Model.OrderNumber </div>
                                            </div>

                                            <div class="col-xs-12">
                                                <table class="table table-striped table-bordered">

                                                    <tr>
                                                        <td>Description</td>
                                                        <td>@Html.DisplayFor(model => model.Description)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Customer Name</td>
                                                        <td>@Html.DisplayFor(model => model.CustomerUserId)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Invoice Number</td>
                                                        <td>@Html.DisplayFor(model => model.invoiceNo)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Order Number</td>
                                                        <td>@Html.DisplayFor(model => model.OrderNo)</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Quantity</td>
                                                        <td>@Html.DisplayFor(model => model.Quantity)</td>
                                                    </tr>


                                                </table>
                                            </div>
                                        </div>
                                    </section>


                                </div>
                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>

                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</section>

