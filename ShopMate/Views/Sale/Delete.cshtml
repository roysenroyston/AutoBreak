@model ShopMate.Models.Sale

@{
    ViewBag.Title = "Are you sure you want to delete";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}


@Html.StarkAjaxFormSubmiter("frmSale", "tbSale", true, "Action Successfully Executed")

@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}

<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of Sale</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">
                  
                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>CustomerUserId</td>
                                    <td>@Html.DisplayFor(model => model.CustomerUserId)</td>
                                </tr>
                                <tr>
                                    <td>Quantity</td>
                                    <td>@Html.DisplayFor(model => model.Quantity)</td>
                                </tr>
                                <tr>
                                    <td>SalePrice</td>
                                    <td>@Html.DisplayFor(model => model.SalePrice)</td>
                                </tr>
                                <tr>
                                    <td>PaymentModeId</td>
                                    <td>@Html.DisplayFor(model => model.PaymentModeId)</td>
                                </tr>
                                <tr>
                                    <td>TotalAmount</td>
                                    <td>@Html.DisplayFor(model => model.TotalAmount)</td>
                                </tr>
                                <tr>
                                    <td>PaidAmount</td>
                                    <td>@Html.DisplayFor(model => model.PaidAmount)</td>
                                </tr>
                                <tr>
                                    <td>ProductId</td>
                                    <td>@Html.DisplayFor(model => model.ProductId)</td>
                                </tr>
                                <tr>
                                    <td>DateAdded</td>
                                    <td>@Html.DisplayFor(model => model.DateAdded)</td>
                                </tr>
                                <tr>
                                    <td>ModifiedBy</td>
                                    <td>@Html.DisplayFor(model => model.ModifiedBy)</td>
                                </tr>
                                <tr>
                                    <td>DateModied</td>
                                    <td>@Html.DisplayFor(model => model.DateModied)</td>
                                </tr>
                                <tr>
                                    <td>AddedBy</td>
                                    <td>@Html.DisplayFor(model => model.AddedBy)</td>
                                </tr>


                            </table>
                            <div class="box-footer">

                                  @using (Html.BeginForm("Delete", "Sale", FormMethod.Post, new {  id = "frmSale" }))
                                {
                                    @Html.AntiForgeryToken()

                                    @Html.StarkInputButtion("Delete","submit","btn btn-danger","")
                                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



