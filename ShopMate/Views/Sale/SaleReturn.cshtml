@{
    ViewBag.Title = "Sale Return";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}

<script src="~/Content/ckeditor/ckeditor.js"></script>

@Html.StarkAjaxFormSubmiter("frmSale", "tbSale", true, "Action Successfully Executed")
 
@{
    if (!Ajax.IsThisAjaxRequest())
    {
        <section class="content-header">
            <h1>
                @ViewBag.Title
                <small>@ViewBag.Title</small>
            </h1>
        </section>
    }
}

<script type="text/javascript">
    $(function () {
        $('select').searchableOptionList({
            maxHeight: '250px'
        });
    });
    function multi() {
        var Quantity = $("#Quantity").val();
        var UnitPrice = $("#UnitPrice").val();
        var TotalAmount = Quantity * UnitPrice;
        $("#TotalAmount").val(TotalAmount);
    }
</script>

@using (Html.BeginForm("SaleReturn", "Sale", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmSale" }))
{
    <section class="content">
        <!-- Small boxes (Stat box) -->
        <div class="row">
            <div class="col-xs-12">
                <div class="box box-solid box-primary">
                    <div class="box-header">
                        <h3 class="box-title">Sale Return</h3>
                    </div>
                    <!-- form start -->

                    <div role="form">
                        <div class="box-body">
                         
                            <div class="form-group">
                                <label>Quantity</label> 
                                <input type="number" value="@ViewBag.qty" name="Quantity" />
                            </div>
                            
                            <div class="form-group">
                                <input type="hidden" name="id" value="@ViewBag.purchaseid" /> 
                            </div>
                             
                        </div><!-- /.box-body -->
                        <div class="box-footer">
                            @Html.StarkInputButtion("Return", "submit", "btn btn-primary", "") 
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section> 
}


