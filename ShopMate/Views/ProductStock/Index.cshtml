            ]

            });

            });
</script>

<section class="content-header">
    <h1>
        @ViewBag.Title
        <small> @ViewBag.Title</small>
    </h1>
</section>

<section class="content">
    <div class="row">
        <div class="col-xs-12">
            <div class="box box-solid box-primary">

                <div class="box-body">
                    <div class="margin">
                        <div class="btn-group">
                            @Ajax.ModalDialogActionLink("Create Quick", "Create", "Create ", "btn btn-dropbox")
                        </div>
                        <div class="btn-group">
                            <a href="~/ProductStock/Create" class="btn btn-default">Adjust Stock</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">@ViewBag.Title</h3>
                </div>
                <div class="box-body table-responsive">

                    <div class="margin">

                        <div class="streaming-table">
                            <span id="found" class="label label-info"></span>

                            <table id="tbProductStock" class="display nowrap">
                                <thead>
                                    <tr>
                                        <th>Actions</th>
                                        <th> Id  </th>
                                        <th> Product  </th>
                                        <th> Quantity  </th>                                                               
                                        <th> Description  </th>
                                        <th> Added By  </th>
                                        <th> Date Added  </th>
                                        <th> Modified By  </th>
                                        <th> Date Modified  </th>
                                        <th> Inventory Type  </th>
                                        <th> Warehouse  </th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>

                            <div id="summary">
                                <div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="box box-solid box-primary">

                <div class="box-body">
                    <div class="margin">
                        <div class="btn-group">
                            @Ajax.ModalDialogActionLink("Create Quick", "Create", "Create ", "btn btn-dropbox")
                        </div>
                        <div class="btn-group">
                            <a href="~/ProductStock/Create" class="btn btn-default">Adjust Stocks</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
</section>






