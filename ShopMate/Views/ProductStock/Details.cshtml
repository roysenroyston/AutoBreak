@model ShopMate.Models.ProductStock

@{
    ViewBag.Title = "Details";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
<section class="content-header">
    <h1>
        @ViewBag.Title
        <small>Details</small>
    </h1>
</section>
<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of ProductStock</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>ProductId</td>
                                    <td>@Html.DisplayFor(model => model.ProductId)</td>
                                </tr>
                                <tr>
                                    <td>Quantity</td>
                                    <td>@Html.DisplayFor(model => model.Quantity)</td>
                                </tr>
                                <tr>
                                    <td>PurchasePrice</td>
                                    <td>@Html.DisplayFor(model => model.PurchasePrice)</td>
                                </tr>
                                <tr>
                                    <td>TotalPurchaseAmount</td>
                                    <td>@Html.DisplayFor(model => model.TotalPurchaseAmount)</td>
                                </tr>
                                <tr>
                                    <td>TotalSaleAmount</td>
                                    <td>@Html.DisplayFor(model => model.TotalSaleAmount)</td>
                                </tr>
                                <tr>
                                    <td>TotalSaleAmountWithTax</td>
                                    <td>@Html.DisplayFor(model => model.TotalSaleAmountWithTax)</td>
                                </tr>
                                <tr>
                                    <td>Discount</td>
                                    <td>@Html.DisplayFor(model => model.Discount)</td>
                                </tr>
                                <tr>
                                    <td>CGST</td>
                                    <td>@Html.DisplayFor(model => model.CGST)</td>
                                </tr>
                                <tr>
                                    <td>CGST_Rate</td>
                                    <td>@Html.DisplayFor(model => model.CGST_Rate)</td>
                                </tr>
                                <tr>
                                    <td>SGST</td>
                                    <td>@Html.DisplayFor(model => model.SGST)</td>
                                </tr>
                                <tr>
                                    <td>SGST_Rate</td>
                                    <td>@Html.DisplayFor(model => model.SGST_Rate)</td>
                                </tr>
                                <tr>
                                    <td>IGST</td>
                                    <td>@Html.DisplayFor(model => model.IGST)</td>
                                </tr>
                                <tr>
                                    <td>IGST_Rate</td>
                                    <td>@Html.DisplayFor(model => model.IGST_Rate)</td>
                                </tr>
                                <tr>
                                    <td>TaxId</td>
                                    <td>@Html.DisplayFor(model => model.TaxId)</td>
                                </tr>
                                <tr>
                                    <td>OtherTaxValue</td>
                                    <td>@Html.DisplayFor(model => model.OtherTaxValue)</td>
                                </tr>
                                <tr>
                                    <td>Description</td>
                                    <td>@Html.DisplayFor(model => model.Description)</td>
                                </tr>
                                <tr>
                                    <td>AddedBy</td>
                                    <td>@Html.DisplayFor(model => model.AddedBy)</td>
                                </tr>
                                <tr>
                                    <td>DateAdded</td>
                                    <td>@Html.DisplayFor(model => model.DateAdded)</td>
                                </tr>
                                <tr>
                                    <td>ModifiedBy</td>
                                    <td>@Html.DisplayFor(model => model.ModifiedBy)</td>
                                </tr>
                                <tr>
                                    <td>DateModied</td>
                                    <td>@Html.DisplayFor(model => model.DateModied)</td>
                                </tr>
                                <tr>
                                    <td>InventoryTypeId</td>
                                    <td>@Html.DisplayFor(model => model.InventoryTypeId)</td>
                                </tr>
                                <tr>
                                    <td>SalePrice</td>
                                    <td>@Html.DisplayFor(model => model.SalePrice)</td>
                                </tr>
                                <tr>
                                    <td>TaxAmount</td>
                                    <td>@Html.DisplayFor(model => model.TaxAmount)</td>
                                </tr>
                                <tr>
                                    <td>Profit</td>
                                    <td>@Html.DisplayFor(model => model.Profit)</td>
                                </tr>
                                <tr>
                                    <td>ProfitWithTax</td>
                                    <td>@Html.DisplayFor(model => model.ProfitWithTax)</td>
                                </tr>
                                <tr>
                                    <td>WarehouseId</td>
                                    <td>@Html.DisplayFor(model => model.WarehouseId)</td>
                                </tr>

 
                            </table>
                            <div class="box-footer">
                                @Ajax.ModalDialogActionLink("Edit", "Edit/" + Model.Id, "Edit", "btn btn-primary") 
                                 
                                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



