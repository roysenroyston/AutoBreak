@model ShopMate.ModelDto.GRVDto
@{
    ViewBag.Title = "GOODS RECEIVED VOUCHER";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
@*<script src="https://cdn.datatables.net/1.10.23/js/jquery.dataTables.min.js"></script>*@
@*<script src="https://cdn.datatables.net/buttons/1.6.5/js/dataTables.buttons.min.js"></script>*@
@*<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.flash.min.js"></script>*@
@*<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>*@
@*<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>*@
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/1.6.5/js/buttons.html5.min.js"></script>
<script src=" https://cdn.datatables.net/buttons/1.6.5/js/buttons.print.min.js"></script>

@{
    string css1 = Url.Content("~/Content/theme/bootstrap/css/bootstrap.min.css");
}


<script type="text/javascript">
    $("#btnPrint").live("click", function () {
        var divContents = $("#dvContainer").html();
        var printWindow = window.open('', '', 'height=700,width=900');
        printWindow.document.write('<html><head>');
        printWindow.document.write('<link href="../../Content/theme/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />');

        printWindow.document.write('</head><body >');
        printWindow.document.write(divContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();

    });


</script>


<style>
    select {
        width: 150px;
    }
    <!-- https://www.transparenttextures.com/wood-pattern.html -->
</style>




<section class="content" style="background-color: #996600; background-image: url(@Url.Content("~/Content/bg/brick-wall-dark.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">
        <div class="col-xs-2">


            <section class="content">
                <!-- Small boxes (Stat box) -->

                <div class="col-xs-12">

                    <div class="clearfix"></div>
                    <br />


                    <div class="clearfix"></div>

                    <br /><br /><br />


                    <a class="btn btn-app" id="btnPrint">
                        <i class="fa fa-print"></i>
                        Print This
                    </a>

                </div>


            </section>


        </div>

        <div class="col-xs-9">

            <div id="dvContainer" class="content invoice" style=" padding inherit; min-height 312mm; width:100%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;text-align:center;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">

                    <div style="text-align:center;font-size:40px;font-weight:bold;">@Model.companayname</div> @*<div style="text-align:center;font-size:20px;font-weight:bold;color:blue;display:inline-block;margin-right:12%;"> GOODS RECIEVED VOUCHER   </div>*@ <div style="display:inline-block;margin-left:10px;"></div>
                    <div style="text-align:center;font-size:30px;font-weight:bold;color:red;"> GOODS RECEIVED VOUCHER</div>


                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>



                        <div class="row">
                            <div class="col-xs-12">
                                <div style="width:96%;">

                                    <section class="invoice">
                                        <!-- title row -->
                                        <!-- info row -->
                                        <div class="row invoice-info">
                                            <div class="col-sm-3 invoice-col">
                                                <img src="~/Content/bg/toserudo.jpeg" style="width:100px;height:100px;" />
                                                
                                            </div>
                                            <div style="float : right; width :45%;margin-right:10%;">
                                                <address>
                                                    @Html.Raw(Model.CompanyAddress)</br>
                                                    @*@Html.Raw(Model.CompanyContact)</br>*@


                                                </address>
                                                @*From : @Model.supplier<br />*@
                                                Warehouse: @Model.Warehouse<br />
                                                Order Number: @Model.OrderNumber<br />
                                                Received By:@Model.receivedby <br />
                                            </div>
                                            @*<div class="col-sm-4 invoice-col"></div>*@
                                            <!--<div style="float : right; ">
            <span>From </span>

            <address>
                <strong>@Model.supplier</strong><br>-->
                                            @* @Html.Raw(Model.SupplierInfo)*@
                                            <!--</address>
        </div>-->

                                        </div>
                                        <div class="row">
                                            <div class="col-xs-12">
                                                <h2 class="page-header">
                                                    @*<i class="fa fa-globe"></i> Invoice #@Model.InvoiceId*@
                                                    <i class="fa fa-globe"></i> GRV No. <label style="color:red;">@Model.Id</label>
                                                    <small class="pull-right">Date:@DateTime.Now.ToString("MMM/dd/yyyy") </small>
                                                </h2>
                                            </div>
                                            <!-- /.col -->
                                        </div>
                                        <!-- /.row -->
                                        <!-- Table row -->
                                        <div class="row">
                                            <!--<div class="col-xs-12">-->
                                                @*<div class="col-xs-5"></div>*@
                                                <!--<div class="col-xs-4" style="margin-left:25%;width:45%;">
                                                    Order Number: @Model.OrderNumber<br />
                                                    Received By:@Model.receivedby <br />
                                                </div>
                                            </div>-->
                                            <div class="clearfix"></div>
                                            <br />

                                            <div class="col-xs-12">
                                                <table class="table table-striped">
                                                    <thead style="background-color:#e5e2e2;">
                                                        <tr>
                                                            <th>Name</th>
                                                            <th>Product Description</th>
                                                            <th>Quantity</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in Model.items)
                                                        {
                                                            <tr>
                                                                <td>@item.Name </td>
                                                                <td>@item.Description</td>
                                                                <td>@item.Quantity</td>
                                                                <td>@item.Status</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </section>


                                </div>
                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>

                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                        <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</section>

