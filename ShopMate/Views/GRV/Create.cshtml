        //Add Multiple Materails.
        $("#addToList").click(function (e) {
            e.preventDefault();

            // if ($.trim($("#quantity").val()) == "" || $.trim($("#description").val()) == "" || $.trim($("#unitPrice").val()) == "") return;

            var quantity = $("#quantity").val(),
                produtId = $("#productid").val(),
                description = $("#description").val(),
                status = $("#status").val(),
                name = $("#Name").val(),
                detailsTableBody = $("#detailsTable tbody");

            var productItem = '<tr><td>' + produtId + '</td><td>' + name + '</td><td>' + description + '</td><td>' + quantity + '</td><td>' + status + '</td><td><a data-itemId="0" href="#" class="deleteItem">Remove</a></td></tr>';
            detailsTableBody.append(productItem);
            clearItem();
        });
        //After Add A New Material In The List, Clear Clean The Form For Add More Material.
        function clearItem() {
            $("#quantity").val('');
            $("#description").val('');
            $("#status").val('');

        }
        // After Add A New Order In The List, If You Want, You Can Remove It.
        $(document).on('click', 'a.deleteItem', function (e) {
            e.preventDefault();
            var $self = $(this);
            if ($(this).attr('data-itemId') == "0") {
                $(this).parents('tr').css("background-color", "#ff6347").fadeOut(800, function () {
                    $(this).remove();
                });
            }
        });

        //After Click Save Button Pass All Data View To Controller For Save Database
        function saveOrder(data) {
            return $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: "/GRV/Create",
                data: data,
                success: function (result) {
                    alert(result);
                    location.reload();
                },
                error: function () {
                    alert("Error!")
                }
            });
        }
        //Collect Multiple JobCard List For Pass To Controller
        $("#saveOrder").click(function (e) {
            e.preventDefault();

            var GRVArr = [];

            GRVArr.length = 0;

            $.each($("#tbInvoiceItem tbody tr"), function () {
                GRVArr.push({
                    ProductId: $(this).find('td:eq(0)').html(),
                    Name: $(this).find('td:eq(1)').html(),
                    Description: $(this).find('td:eq(2)').html(),
                    quantity: $(this).find('td:eq(3)').html(),
                    status: $(this).find('td:eq(4)').html(),
                    //unitPrice: $(this).find('td:eq(2)').html(),
                    //TotalPrice: $(this).find('td:eq(3)').html()
                });
            });

            var data = JSON.stringify({
                receivedby: $("#receivedby").val(),
                OrderNumber: $("#OrderNumber").val(),
                supplier: $("#supplier").val(),
                Warehouse: $("#warehouse").val(),
                GRVMaterials: GRVArr
            });

            $.when(saveOrder(data)).then(function (response) {
                console.log(response);
            }).fail(function (err) {
                console.log(err);
            });
        });
</script>


