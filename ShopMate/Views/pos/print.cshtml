@model ShopMate.ModelDto.InvoiceDto
@{
    ViewBag.Title = "INVOICE";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery1.8.3.print.js"></script>

<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
