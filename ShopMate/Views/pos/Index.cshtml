    function addInv(id, price, tax, name, remaining) {
    var qty = parseInt(document.getElementById("Qty" + id).value);

    if (qty > 0) {
        if (parseInt(remaining) >= qty) {
            var existingRow = $("#tbody").find("#" + id);

            console.log(existingRow)
            if (existingRow.length > 0) {
                // Update the quantity and total for the existing row
                var existingQty = parseInt(existingRow.attr("qty"));
                var newQty = existingQty + qty;
                var total = newQty * parseFloat(price);
                var taxAmount = (parseFloat(tax) / 100) * total;
                var grossTotal = total; // + taxAmount

                existingRow.attr("qty", newQty);
                existingRow.find("td:nth-child(4)").text(newQty); // Update the quantity cell
                existingRow.find("td:nth-child(5)").text(grossTotal); // Update the total cell
            } else {
                // Add a new row
                var total = qty * parseFloat(price);
                var taxAmount = (parseFloat(tax) / 100) * total;
                var grossTotal = total; // + taxAmount

                @*var rowHtml = '<tr class="item-row" id="' + id + '" qty="' + qty + '"> \
                                   <td><a class="delete" value="' + grossTotal + '" href="javascript:;" title="Remove row">X</a> &nbsp; ' + name + '</td> \
                                   <td>' + price + '</td> \
                                   <td><option class="selecttax" value="VAT @' + tax + '%">VAT @' + tax + '%</option>@Html.Raw(ViewBag.moreTax)</td> \
                                   <td>' + qty + '</td> \
                                   <td>' + grossTotal + '</td> \
                               </tr>';

                $("#tbody").append(rowHtml);*@
                 var div = '<tr class="item-row" id="' + id + '"  qty="' + qty + '" >   <td> <a class="delete" value="' + grosstotal + '" href="javascript:;" title="Remove row">X</a> &nbsp; ' + name + '</td> <td>' + price + '</td> <td> <option class="selecttax" value="VAT @@' + tax + '%">VAT @@' + tax + '%</option>@Html.Raw(ViewBag.moreTax) </td>  <td>' + qty + '</td> <td>' + grosstotal + '</td>   </tr>';

                             $("#tbody").append(div);
            }

            cleartext();
            GrossAmount(grossTotal);
            currenciesListInputChange();
            $("#divPayout").show();
        } else {
            if (parseInt(remaining) > 0) {
                alert("Product Stock " + remaining + " left");
                cleartext();
            } else {
                cleartext();
                var proceed = window.confirm("Not enough stock?");
                if (proceed) {
                    $.ajax({
                        url: '/Product/Autobreak',
                        type: 'POST',
                        data: JSON.stringify({ id: id }),
                        contentType: 'application/json; charset=utf-8',
                        success: function (data) {
                            window.location = "@Env.GetSiteRoot()/POS/";
                        }
                    });
                }
            }
        }
    } else {
        alert("Increase Quantity First");
    }
}





    function GrossAmount(amount)
    {
        var oldAmount = $("#GrossAmount").val();
        var total = parseFloat(oldAmount) + parseFloat(amount);

        $("#GrossAmount").val(total.toFixed(2));

        CustomerChange();
    }

    function CustomerChange() {

        var fromcustomer = $("#tmoney").val();

        var gross = $("#GrossAmount").val();
        //var gross = $("#NewID").val();
        var change = fromcustomer - parseFloat(gross);
        $("#ichange").val(change.toFixed(2));
        $("#tenderedmoney").text(fromcustomer);

    }
