@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section ScriptsOrCss
{
    <link href="~/Content/DataTable/new/dataTables.bootstrap.css" rel="stylesheet" type="text/css" />
    <script src="~/Content/DataTable/new/jquery.dataTables.min.js" type="text/javascript"></script>
    <link href="~/Content/DataTable/new/jquery.dataTables.min.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/quagga.js"></script>
}

<style>
    #tbProduct_wrapper select {
        display: none;
    }

    #tbProduct_filter input {
        width: 190px;
        margin-right: 20px;
    }

    .selecttax {
        font-size: 11px;
        height: 20px;
        padding: 0;
        width: 150px;
    }
</style>

<script type="text/javascript">

    $(document).on("keypress", function (e) {
        if (e.which == 13) {
            document.getElementById("btnPlus").click();
        }
    });
    let data = '';

    window.onload = function () {
        window.document.body.addEventListener('keydown', function (event) {


            if (event.ctrlKey) {
                event.preventDefault();
                return;
            }

            data += event.key;
            console.log(data);
        });
    }

    $(document).ready(function () {

        getproducts();
          updatep();
    });
    function cleartext(){
        $('.dataTables_filter input').val('');
    }
    function getproducts() {
        var oTableProduct = "";
        var ControlerNameProduct = "@Url.Content("~/pos")";
        // debugger; this is the product from get product in pos controler
        oTableProduct = $("#tbProduct").dataTable({
            "bRetrieve": true,
            "bProcessing": true,
            "dom": 'lBfrtip',
            "sAjaxSource": "@Url.Content("~/pos/GetProduct")",
            "pageLength": 50,
            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
            "aoColumns": [
                 {
                     "mRender": function (oObj, type, row,full) {

                         var content = '<img src="/Uploads/' + row[3] + '" style="width:50px;height:50px;" /> &nbsp;<b>' + row[6] + '</b>&nbsp;' + row[0] + ' <br/><b>Price: ' + row[1] + '</b> <br/>Remain:<input type="number" value="'+ row[7] +'" style="width:44px;" id="remainq" readonly/>';

                         return content;
                     }

                 },

            {
                "mRender": function (oObj, type, row) {


                    var buttons = '<div class="text-center"> <input type="number" value="1" style="width:44px;" id="Qty' + row[2] + '"/> <button onclick="addInv(' + row[2] + ',' + row[4] + ',' + row[5] + ',\'' + row[0] + '\','+row[7]+')" type="button" id="btnPlus" class="btn btn-default btn-xs btn-warning" title="Click To Add" > <i class="fa fa-plus"></i></button></div>';

                    return buttons;
                }

            },

            ]

        });

        $(".dataTables_filter input").on("keypress", function (e) {
            if (e.which == 13) {
                document.getElementById("btnPlus").click();
            }
        });

        $("#tbody").on('click', ".delete", function () {
            var amt = $(this).attr("value");
            $(this).parents('.item-row').remove();
            GrossAmount(-amt);
        });

        $("#btnPayOut").on('click', function () {
            if (confirm("are you sure you want to payout!") == true) {
                var products = [];
                //var quantity = [];

                $("tr.item-row").each(function () {
                    $this = $(this);
                    products.push({ product: $this.attr("id"), qty: $this.attr("qty") });
                    //quantity.push($this.attr("qty"));
                });
               

                if ($("#CustomerUserId").val() >= 0) {
                    //if ($("#PaymentModeId").val()>=0){
                    $.ajax({
                        url: "/pos/accountsale",
                        type: "Post",
                        data: { 'products': products, 'CustomerUserId': $("#CustomerUserId").val(), 'PaymentModeId': $("#PaymentModeId").val(), 'SaleNote': $("#SaleNote").val(), 'TaxName': $(".selecttax").val(), 'gross': $("#grs").val()},
                        dataType: 'json',//json
                        success: function (data) {
                            if (data[0].msg == "Done") {
                                $.sticky('<br/> Sale Successful ', { stickyClass: 'success' });
                                window.location = "@Env.GetSiteRoot()/pos/print/" + data[0].value;
                            }
                            else {
                                $.sticky('<br/> ! Something  went wrong. <br/> ' + data + '', { stickyClass: 'error' });
                            }
                        }, error: function () { $.sticky('<br/> ! Something went wrong. <br/> ' + data + '', { stickyClass: 'error' }); }
                    });
                    //} else {
                    //    $.sticky('<br/> ! Select Payment Mode First. <br/>  ', { stickyClass: 'error' });
                    //}
                }
                else {
                    $.sticky('<br/> ! Select Customer First. <br/>  ', { stickyClass: 'error' });
                }


            }


        });
    }
    function updatep() {

        $("#upbtn").click(function () {


            var catId = $("#usID").val();
            var pernt = $("#amount").val();
            var payment = $("#paymentfor").val();
            var cashacc = $("#cashaccount").val();
            var eco = $("#ecocashaccount").val();
             var swip = $("#swipeaccount").val();
            $.ajax({
                type: "POST",
                //url: "~/UpdatePrice?Id=" + catId + "&addprice=" + pernt + "",
                url: "@Url.Action("Accountpay", "pos")?Ids=" + catId + " &addbalance= " + pernt + " &description=" + payment + " &cash=" + cashacc + " &eco=" + eco + " &swip=" + swip + "",

                datatype: "json",
                data: '{Ids:' + catId + ', addbalance: "' + pernt + '",description: "' + payment + '",cash: "' + cashacc + '",eco: "' + eco + '",swip: "' + swip + '"}',
                success: function () {

                    $("#upbtn").closest("tr").find("td:eq(4)").text(400);
                    $('#progressmodal').modal('hide');


                },
                error: function (req, textStatus, errorThrown) {
                    //this is going to happen when you send something different from a 200 OK HTTP
                    alert('Ooops, something happened: ' + textStatus + ' ' + errorThrown);
                }

            });


        });
    }
    function addInv(id,price,tax,name,remaining)
    {

       // var remainingquantity = document.getElementById("remainq" + id).value;
        var qty = document.getElementById("Qty" + id).value;


        if (parseInt(qty) > 0)
        {
            if (parseInt(remaining) > 0) {



               // if ($("#tbody").find("#" + id).length > 0) { //if row already have then remove old one
                   // $($("#tbody").find("#" + id).find(".delete")).click();
                 //  qty++;

                //}

                var total = (parseFloat(qty) * parseFloat(price));
                var TaxAmount = (parseFloat(tax) / 100) * (parseFloat(total));
                var grosstotal = total;
                // (total + TaxAmount)


                var div = '<tr class="item-row" id="' + id + '"  qty="' + qty + '" >   <td> <a class="delete" value="' + grosstotal + '" href="javascript:;" title="Remove row">X</a> &nbsp; ' + name + '</td> <td>' + price + '</td> <td> <select class="selecttax"><option value="VAT @@' + tax + '%">VAT @@' + tax + '%</option><option value="None @@' + tax + '%">None @@' + tax + '%</option> @Html.Raw(ViewBag.moreTax)  </select> </td>  <td>' + qty + '</td> <td>' + grosstotal + '</td>   </tr>';

                $("#tbody").append(div);
                cleartext();
                GrossAmount(grosstotal);
                currenciesListInputChange();

                $("#divPayout").show();
                }

            else {
                alert("Product Not Available in Stock");
                cleartext();
            }
        }
        else
        {
            alert("Incrise Quantity First");
        }
    }

    function GrossAmount(amount)
    {
        var oldAmount = $("#GrossAmount").text();
        var total = parseFloat(oldAmount) + parseFloat(amount);

        $("#GrossAmount").text(total.toFixed(2));
        $("#grs").val(total.toFixed(2));

    }

</script>

<section class="content" style="background-color: #ff0000; background-image: url(@Url.Content("~/Content/bg/woven-light.png"));">
    <!-- Small boxes (Stat box)  -->
    <div class="row">

        <div class="col-xs-4" style="padding-right:0px;">

            <section class="content">

                <div class="col-xs-12" style="padding-left:0px;height:640px;overflow:auto;">

                    <div class="clearfix"></div>
                    <br />

                    <table id="tbProduct" class="display">
                        <thead>
                            <tr>
                                <th style="width:150px !important;"> Product  </th>
                                <th style="width:100px !important;"> Qty  </th>


                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="clearfix"></div>
                    <br />

                </div>

                <div class="clearfix"></div>
                <br />
            </section>

        </div>

        <div class="col-xs-8" style="padding-left:0px;padding-right:0px;">
            <div id="barcode-scanner" style="display:none;"></div>
            <a href="~/Sale/" class="btn btn-block btn-default btn-xs">Go To Sale List</a>
            <div class="btn-group">
                <button id="accountpay" class="btn btn-success" data-target="#progressmodal" data-toggle="modal">Account Payment</button>

            </div>
            <div id="dvContainer" class="content invoice" style="padding: inherit; min-height: 135mm;  width:93%; ">

                <div style="margin-bottom:50px;">

                </div>
                <div class="row" style="font-size:12px;text-align:center;font-weight:bold;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;">


                    <div style="text-align:center;font-size:30px;font-weight:bold;">Point Of Sale</div>


                    <div style="text-align:left;margin-left:40px;">

                        <div style="height:10px; margin-bottom:10px; ">

                        </div>

                        <div class="row">

                            <div class="col-xs-12">

                                <div style="width:96%;">
                                    <table id="tbInvoiceItem" class="table table-striped table-bordered">
                                        <thead style="background-color:#e5e2e2;">
                                            <tr>

                                                <th>Product Name </th>
                                                <th>Price </th>
                                                <th>Tax </th>
                                                <th>Quantity </th>
                                                <th> Total </th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbody"></tbody>
                                        <tfoot style="background-color:#e5e2e2;">
                                            <tr>
                                                <th> </th>
                                                <th> </th>
                                                <th></th>
                                                <th> </th>
                                                <th> </th>

                                            </tr>

                                            <tr>
                                                <th> </th>
                                                <th> </th>
                                                <th></th>

                                                <th>Gross Amount </th>
                                                <th id="GrossAmount">0</th>
                                            </tr>
                                            
                                        </tfoot>
                                    </table>

                                    <div id="divPayout">
                                        <div>
                                            @Html.DropDownList("CustomerUserId", " -Select Customer- ")<br />
                                        </div>
                                        <div style="display:none">
                                            <input value="0" type="number" class="form-control" id="grs" />
                                        </div>
                                        <div style="display:none">

                                            @Html.DropDownList("PaymentModeId", " -Select Payment Mode- ")<br />
                                            <input type="text" id="SaleNote" placeholder="Any Remarks" value="AccountSale" style="width:325px" readonly />
                                        </div>
                                        <input style="margin-top:10px;" type="button" id="btnPayOut" class="btn btn-primary" value="PayOut And Print" />

                                    </div>
                                </div>


                            </div>


                        </div>
                        <div style="height:10px; margin-bottom:20px;">

                        </div>



                    </div>


                    <div class="clearfix"></div>


                </div>


                <div class="row">
                    <div class="col-xs-12">
                        <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>

                    </div>
                </div>
            </div>

        </div>



    </div>
    <div class="modal" id="progressmodal" data-keyboad="false" data-backdrop="static" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">Account Payment</h4>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body" id="progrdata">
                    <div class="form-group">
                        <label id="pincdelb">Customer Name</label>
                        @*" -Select- "*@
                        @*@ @Html.DropDownList("UserId", new { @id = "usID" }, " -Select- ") *@
                        @Html.DropDownList("UserId", null, new { @id = "usID" })
                        @Html.StarkDropDownAjaxLink("/User/CreateCustomer", "AddMore", "")

                    </div>
                    <div class="form-group">
                        <label>Amount Paid</label>
                        <input type="number" id="amount" readonly/>
                    </div>
                    <div class="md-form">
                        <label for="form10">Payment For</label>
                        <i class="fas fa-pencil-alt prefix"></i>
                        <textarea id="paymentfor" class="md-textarea form-control" rows="3"></textarea>

                    </div>
                    <div>
                        <table>
                            <thead>
                                <tr>

                                    <th>Cash</th>
                                    <th>Ecocash</th>
                                    <th>Swipe</th>
                                    <th>Telecash</th>
                                    <th>One Money</th>
                                    <th>USD</th>
                                    <th>Rand</th>
                                    <th>Pula</th>

                                </tr>

                            </thead>
                            <tr>
                                <td><input value="0" type="number" class="form-control" id="cashaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="ecocashaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="swipeaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="telecashaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="onemoneyaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="usdaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="randaccount" /></td>
                                <td><input value="0" type="number" class="form-control" id="pulaaccount" /></td>
                            </tr>

                        </table>
                    </div>
                </div>
            
                <div class="modal-footer">
                    <button type="button" class="btn-primary" id="upbtn">PayOut</button>
                    <button class="btn-primary" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

</section>
<script>

    var cashToCurrencyConvertorUrl = '/pos/CashToCurrencyConvertor';
    var currencyToCashConvertorUrl = '/pos/CurrencyToCashConvertor';

    $(function () {
        $("#currencyDropDown").change(function () {

            var selectedCurrency = $(this).children("option:selected").text();
            var amountFromCustomer = $("#amount").val() ? $("#amount").val() : 0.00;
            var amountToBeConverted = $("#GrossAmount").val() - amountFromCustomer;

            $.ajax({
                type: "GET",
                url: cashToCurrencyConvertorUrl,
                contentType: "application/json",
                data: {
                    "selectedCurrecy": selectedCurrency,
                    "amountToBeConverted": amountToBeConverted
                },
                datatype: "json",
                success: function (data) {
                    $("#NewID").val(data.toFixed(2));
                },
                error: function () {
                    console.log(error);
                    alert("Dynamic content load failed.");
                }
            });
        });

        $("#cashaccount, #usdaccount, #randaccount, #pulaaccount, #ecocashaccount, #swipeaccount, #telecashaccount, #onemoneyaccount").on("input", function () {
            findCustomerAmountByCurrencies();
        });

        function findCustomerAmountByCurrencies() {

            getAmountsCurrenciesInTextboxes();

            $.ajax({
                type: "POST",
                url: currencyToCashConvertorUrl,
                contentType: "application/json",
                data: JSON.stringify({ "currencyAmounts": amountsCurrenciesInTextboxes }),
                datatype: "json",
                success: function (data) {

                    $("#tmoney").val(data.toFixed(2))
                    CustomerChange();
                },
                error: function () {
                    console.log(error);
                    alert("Dynamic content load failed.");
                }
            });
        }
    });

</script>

