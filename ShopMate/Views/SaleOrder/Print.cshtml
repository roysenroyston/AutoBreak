<section id="whole-section" class="content" style="background-image: url(@Url.Content("~/Content/bg/mining.jpg"))">
    <div class="row">
        @*<div class="col-xs-2 no-print">
                <section class="content">
                    <div class="col-xs-12">
                        <a class="btn btn-app" id="btnPrint">
                            <i class="fa fa-print"></i>
                            Print Invoice
                        </a>
                    </div>
                </section>
            </div>*@

        <div class="col-xs-12 print">
            <div id="print-content" class="content invoice">
             
                <span class="Fiscal-Heading" style="text-align:center;margin-left:0%; font-weight: bold;"><h3> <strong>  SALE ORDER</strong></h3></span>
                <figure>
                    <img id="KediLogo" class="pull-left" img src="~/Content/bg/kedimec.jpeg" style="width:250px; height:200px;margin-top:2%;margin-left:1%;" />
                </figure>

                <div class="pull-right" style="text-align: left; margin-left: 2%; margin-top: 1%; margin-right: 2%; font-size: 11px; width: 30%;">

                    <div id="KediAddress">
                        <kediAddress>
                            <strong> @Model.CompanyName<br></strong>
                            @Html.Raw(Model.CompanyAddress)<br>
                            @Html.Raw(Model.CompanyContact)/ 0552525857 <br /> <br />
                            <kediAddress>
                    </div>

                    <span><strong>Bill To:</strong></span>
                    <address>
                        @Model.BranchName <br />
                        @*@Html.Raw(Model.ToInfo)*@
                        Customer VAT No: @Model.vatNo <br />
                        Order No:@Model.CustomerorderNumber<br />

                    </address>




                </div>
                <p>&nbsp;&nbsp;</p>
                <p>&nbsp;&nbsp;</p>
                <p>&nbsp;&nbsp;</p>


                <div class="invoice-body">
                    <div class="Table-Area-Container">
                        <p>&nbsp;&nbsp;</p>
                        <p>&nbsp;&nbsp;</p>
                        <p>&nbsp;&nbsp;</p>
                        @*<span class="Fiscal-Heading" style="text-align:left;margin-left: 1%;"><h2> SALE ORDER</h2></span>*@
                        <div style="width:100%;">
                            <section>
                                <div class="Table-Area">
                                    <table class="table" style="font-size: 11px; width: 98%;height: auto;font-weight: 200; position: relative;">
                                        <thead style="background-color:#e5e2e2;">
                                            <tr>
                                                @*<th class="heading-print">CODE</th>*@
                                                <th class="heading-print">CODE</th>
                                                <th class="heading-print">DESCRIPTION</th>
                                                <th class="heading-print">QUANTITY</th>
                                                <th class="heading-print">PRICE</th>
                                                <th class="heading-print">VAT </th>
                                                <th class="heading-print">TOTAL</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.services != null)
                                            {
                                                if (Model.services.Count > 0)
                                                {
                                                    foreach (var item in Model.services)
                                                    {
                                                        <tr>
                                                            @*<td class="data-print">@item.Code</td>*@
                                                            <td class="data-print">@item.productn</td>
                                                            <td class="data-print">@item.description</td>
                                                            <td class="data-print">@item.quantity</td>
                                                            <td class="data-print">@item.rates</td>
                                                            <td class="data-print">@item.vat</td>
                                                            <td class="data-print">@item.total</td>
                                                        </tr>

                                                    }
                                                }
                                            }

                                        </tbody>
                                    </table>
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <br />
                                    <div id="footer " style="display: block; width: 98%;  height: 280px; position: relative; page-break-inside: avoid; ">
                                        <div style="float: none; position: static; overflow: visible;  page-break-inside: avoid;">
                                            <div class="pull-right" style="text-align: left; margin-left: 2%; font-weight: bold; margin-right: 0%; margin-top: 1%; page-break-inside: avoid; font-size: 11px; width: 17%;">
                                                Total(Excl):&nbsp;@Model.CurrencySymbol @Model.SubTotal
                                                <p>&nbsp;&nbsp;</p>
                                                Tax:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Model.CurrencySymbol @Model.Tax
                                                <p>&nbsp;&nbsp;</p>
                                                @*Discount:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Model.CurrencySymbol @Model.discount
                    <p>&nbsp;&nbsp;</p>*@
                                                Total(Incl):&nbsp;&nbsp;@Model.CurrencySymbol @Model.TotalAmount
                                            </div>
                                            <br />
                                            <br />
                                            <br />
                                            <br />
                                            <br />

                                            <div class="bank-title" style="font-weight:bold;text-align: left;margin-left:0%;"><h4><strong>Our Banking Details</strong></h4></div>

                                            <div class="Banking-Details pull-left" style="float: left; margin-top: 3.5%; left: 10px; font-size: 10px; width: 30%; margin-left: 0%; page-break-inside: avoid;">
                                                @*<h4 class="bank-title" style="margin-left:0%;"><strong>Our Banking Details</strong></h4>*@

                                                <div id="first-bank">
                                                    <h5>
                                                        <strong>RTGS Account</strong><br />
                                                        Name&nbsp;&nbsp;: Barclays Bank<br>
                                                        Acc No &nbsp;&nbsp;: 1058950<br />
                                                        Branch Code &nbsp;&nbsp;  : 2144<br />
                                                        Branch &nbsp;&nbsp;  : Pearl House <br />
                                                    </h5>
                                                </div>


                                            </div>
                                            <div class="Second-Account" style="float: left; font-size: 10px; text-align: left; margin-top: 3.5%; left: 50px; width: 28%;">
                                                <h5>
                                                    <strong>RTGS Account</strong><br />
                                                    Name&nbsp;&nbsp;: Stanbic Bank<br>
                                                    Acc No &nbsp;&nbsp;: 9140002840293<br />
                                                    Branch &nbsp;&nbsp;  : Msasa, Harare <br />
                                                </h5>
                                            </div>
                                            <div class="Second-Account" style="float: right; text-align: left; font-size: 10px; right: 0%; margin-top: 3%; width: 35%;">
                                                <h5>
                                                    <strong>Nostro Account</strong><br>
                                                    Name&nbsp;&nbsp;: Stanbic Bank<br>
                                                    Acc No &nbsp;&nbsp;: 9140001350675<br />
                                                    Branch &nbsp;&nbsp;  : Msasa, Harare <br />
                                                </h5>
                                            </div>


                                        </div>

                                    </div>

                                </div>
                            </section>
                        </div>
                    </div>



                    <div class="clearfix no-print"></div>
                    <div class="clearfix no-print"></div>
                    @*<div class="row no-print" id="Footer-Area">
                <div class="col-xs-12" style="text-align:left">
                    <p style="font-weight:700; font-style:italic;"></p>
                    <h4 style="font-weight:700; font-style:italic;align-self:center;">@Html.Raw(Model.InvoiceFooterText)</h4>
                </div>
            </div>*@
                </div>
                @*<div style="height:10px; margin-bottom:20px;"></div>*@
            </div>
            <div class="clearfix no-print"></div>
        </div>
        @*<div class="row no-print">
                <div class="col-xs-12">
                    <div class="col-xs-5" style="padding-left:60px;"> @DateTime.Now.ToString("dd/MMM/yyyy hh:mm:tt")</div>
                    <div class="col-xs-4" style="margin-left:25%;padding-left:80px;">Printed by: @Env.GetUserInfo("name") </div>
                </div>
            </div>*@
    </div>
    <div class="no-print">
        <a class="btn btn-app" id="btnPrint"onclick="window.print()">
            <i class="fa fa-print"></i>
            Print Invoice
        </a>
    </div>
</section>