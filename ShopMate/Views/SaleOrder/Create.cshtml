<script>

    var cashToCurrencyConvertorUrl = '/pos/CashToCurrencyConvertor';
    var currencyToCashConvertorUrl = '/pos/CurrencyToCashConvertor';

    $(function () {
        $("#currencyDropDown").change(function () {

            var selectedCurrency = $(this).children("option:selected").text();
            var amountFromCustomer = $("#tmoney").val() ? $("#tmoney").val() : 0.00;
            var amountToBeConverted = $("#GrossAmount").val() - amountFromCustomer;

            $.ajax({
                type: "GET",
                url: cashToCurrencyConvertorUrl,
                contentType: "application/json",
                data: {
                    "selectedCurrecy": selectedCurrency,
                    "amountToBeConverted": amountToBeConverted
                },
                datatype: "json",
                success: function (data) {
                    $("#NewID").val(data.toFixed(2));
                },
                error: function () {
                    console.log(error);
                    alert("Dynamic content load failed.");
                }
            });
        });

        $("#cashtxt, #usdtxt, #randtxt, #pulatxt, #ecocashtxt, #swipetxt, #telecashtxt, #onemoneytxt").on("input", function () {
            findCustomerAmountByCurrencies();
        });

        function findCustomerAmountByCurrencies() {

            getAmountsCurrenciesInTextboxes();

            $.ajax({
                type: "POST",
                url: currencyToCashConvertorUrl,
                contentType: "application/json",
                data: JSON.stringify({ "currencyAmounts": amountsCurrenciesInTextboxes }),
                datatype: "json",
                success: function (data) {

                    $("#tmoney").val(data.toFixed(2))
                    CustomerChange();
                },
                error: function () {
                    console.log(error);
                    alert("Dynamic content load failed.");
                }
            });
        }
    });

</script>

