    function GrossAmount(amount)
    {
        var oldAmount = $("#GrossAmount").val();
        var total = parseFloat(oldAmount) + parseFloat(amount);

        $("#GrossAmount").val(total.toFixed(2));

        CustomerChange();
    }

    function CustomerChange() {

        var fromcustomer = $("#tmoney").val();

        var gross = $("#GrossAmount").val();

        var change = fromcustomer - parseFloat(gross);
        $("#ichange").val(change.toFixed(2));
        $("#tenderedmoney").text(fromcustomer);

    }
