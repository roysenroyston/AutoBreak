    function currenciesListInputChange() {
        // variables  for the currencies
        var baseCurrencyAmount, baseRate, baseTendered, baseBalance, baseChange;
        var bondRate, bondTendered, bondBalance, bondChange;
        var rtgsRate, rtgsTendered, rtgsBalance, rtgsChange;
        var ecocashRate, ecocashTendered, ecocashBalance, ecocashChange;
        var oneMoneyRate, oneMoneyTendered, oneMoneyBalance, oneMoneyChange;
        var teleCashRate, teleCashTendered, teleCashBalance, teleCashChange;
        var zwlRate, zwlTendered, zwlBalance, zwlChange;

        //Base Currency
        baseCurrencyAmount = $('#GrossAmount').text();
        baseRate = $('#GrossAmount').text();
        baseTendered = 0.00;
        baseBalance = baseRate;
        baseChange = 0.00;

        $('#usdrate').val(baseRate);
        $('#usdtendered').val(baseTendered.toFixed(2));
        $('#usdchange').val(baseChange.toFixed(2));
        $('#usdtendered').on('click', function () {
            $(this).select();
        });
        $('#usdtendered').on('input', function () {
            var rate, tender, change, balance;
            rate, balance = baseRate;
            tender = $('#usdtendered').val();
            if ((tender - baseBalance) > 0) {
                $('#usdchange').val(parseFloat(tender - baseBalance).toFixed(2));
                $('#usdbalance').val(0.00.toFixed(2)) && $('#fcabalance').val(0.00.toFixed(2)) && $('#rgtsbalance').val(00.toFixed(2));
            } else {
                $('#usdbalance').val(parseFloat(baseBalance - tender).toFixed(2));
                $('#usdchange').val(0.00.toFixed(2));
            }
        });
        $('#usdbalance').val(baseBalance);

        $('#fcarate').val(baseRate);
        $('#fcatendered').val(baseTendered.toFixed(2));
        $('#fcabalance').val(baseBalance);
        $('#fcachange').val(baseChange.toFixed(2));

        //RTGS  Dollar
        rtgsrate = baseCurrencyAmount * 7;
        rtgstendered = 0.00;
        rtgsbalance = rtgsrate;
        rtgschange = 0.00;

        $('#rgtsrate').val(parseFloat(rtgsrate));
        $('#rgtstendered').val(0.00.toFixed(2));
        $('#rgtsbalance').val(rtgsbalance.toFixed(2));
        $('#rgtschange').val(0.00.toFixed(2));

        //Bond Note
        $('#bondrate').val(baseRate);
        $('#bondtendered').val(baseTendered.toFixed(2));
        $('#bondbalance').val(baseBalance);
        $('#bondchange').val(baseChange.toFixed(2));

        ////Ecocash
        $('#ecocashrate').val(parseFloat(baseRate * 7.25));
        $('#ecocashtendered').val(baseTendered.toFixed(2));
        $('#ecocashbalance').val(baseBalance);
        $('#ecocashchange').val(baseChange.toFixed(2));

        ////Telecash
        $('#telecashrate').val(parseFloat(baseRate * 7.5));
        $('#telecashtendered').val(baseTendered.toFixed(2));
        $('#telecashbalance').val(baseBalance);
        $('#telecashchange').val(baseChange.toFixed(2));

        ////Onemoney
        $('#onemoneyrate').val(parseFloat(baseRate * 7.2));
        $('#onemoneytendered').val(baseTendered.toFixed(2));
        $('#onemoneybalance').val(baseBalance);
        $('#onemoneychange').val(baseChange.toFixed(2));

    }
