@model ShopMate.Models.User

@{
    ViewBag.Title = "Details";
    if (Ajax.IsThisAjaxRequest())
    {
        Layout = null;
    }
}
<section class="content-header">
    <h1>
        @ViewBag.Title
        <small>Details</small>
    </h1>
</section>
<section class="content">
    <!-- Small boxes (Stat box) -->
    <div class="row">
        <div class="col-xs-12">

            <div class="box box-solid box-primary">
                <div class="box-header">
                    <h3 class="box-title">Detail of User</h3>
                </div><!-- /.box-header -->
                <div class="box-body table-responsive">

                    <div class="widget-sec">
                        <div class="streaming-table">
                            <table class="table table-striped table-bordered">

                                <tr>
                                    <td>UserName</td>
                                    <td>@Html.DisplayFor(model => model.UserName)</td>
                                </tr>
                                <tr>
                                    <td>Password</td>
                                    <td>@Html.DisplayFor(model => model.Password)</td>
                                </tr>
                                <tr>
                                    @*<td>FullName</td>
                                    <td>@Html.DisplayFor(model => model.FullName)</td>
                                </tr>
                                <tr>
                                    <td>Mobile</td>
                                    <td>@Html.DisplayFor(model => model.Mobile)</td>
                                </tr>
                                <tr>
                                    <td>Address</td>
                                    <td>@Html.DisplayFor(model => model.Address)</td>
                                </tr>
                                <tr>
                                    <td>About</td>
                                    <td>@Html.DisplayFor(model => model.About)</td>
                                </tr>
                                <tr>
                                    <td>RoleId</td>
                                    <td>@Html.DisplayFor(model => model.RoleId)</td>
                                </tr>
                                <tr>
                                    <td>JoinDate</td>
                                    <td>@Html.DisplayFor(model => model.JoinDate)</td>
                                </tr>
                                <tr>
                                    <td>IsActive</td>
                                    <td>@Html.DisplayFor(model => model.IsActive)</td>
                                </tr>
                                <tr>
                                    <td>CanLogin</td>
                                    <td>@Html.DisplayFor(model => model.CanLogin)</td>
                                </tr>*@

 
                            </table>
                            <div class="box-footer">
                                @Ajax.ModalDialogActionLink("Edit", "Edit/" + Model.Id, "Edit", "btn btn-primary") 
                                 
                                @*@Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })*@
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



