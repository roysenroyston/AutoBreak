    function saveOrder(data) {
         var customerids = $("#customerid").val();
        if (customerids >= 0) {
        return $.ajax({
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            type: 'POST',
            url: "/Invoice/NewInvoice",
            data: data,
            success: function (result) {
                if (result[0].msg == "Submitted"){
                              $.sticky('<br/> Sale Successful ', { stickyClass: 'success' });
                    if (result[0].isformal == true) {
                        window.location = "@Env.GetSiteRoot()/Invoice/Printformal/" + result[0].value;
                    }
                    else {
                       window.location = "@Env.GetSiteRoot()/Invoice/PrintInformal/" + result[0].value;
                    }

                }

                @*alert(result);
                location.reload();
                window.location = "@Env.GetSiteRoot()/Invoice/print/" + data[0].value;*@
            },
            error: function (req, textStatus, errorThrown) {
                //this is going to happen when you send something different from a 200 OK HTTP
                $.sticky('<br/> ! Select Customer first. <br/>  ', { stickyClass: 'error' });
                 //$.sticky('<br/> ! Not enough stock to perform action <br/>  ', { stickyClass: 'error' });
            }
        });
        }
        else {
                $.sticky('<br/> ! Select Customer first. <br/>  ', { stickyClass: 'error' });
             }
