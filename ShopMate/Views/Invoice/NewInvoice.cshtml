     function GrossAmount(amount, tax) {
         var oldAmount = $("#subtotal").val();
         var newAmount = parseFloat(amount)/* - parseFloat(tax)*//*;*/
         var Sutotal = parseFloat(oldAmount) + parseFloat(newAmount);
         var oldtax = $("#vattotal").val();
         var taxs =  parseFloat(oldtax) + parseFloat(tax);
         var total = parseFloat(Sutotal) + parseFloat(taxs);
         var bal = parseFloat(total);
         $("#subtotal").val(Sutotal.toFixed(2));
         $("#vattotal").val(taxs.toFixed(2));
         $("#total").val(total.toFixed(2));
         $("#balance").val(bal.toFixed(2));

    }
     function balance() {
        var paid = $("#payments").val();

        var tot = $("#balance").val();

         var bala = tot - parseFloat(paid);
         $("#balance").text(bala.toFixed(2));


